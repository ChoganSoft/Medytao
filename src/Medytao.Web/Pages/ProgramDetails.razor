@page "/programs/{Id:guid}"
@implements IDisposable
@inject MeditationService MeditationSvc
@inject ProgramService ProgramSvc
@inject CategoryService CategorySvc
@inject AuthService Auth
@inject NavigationManager Nav
@inject PlaybackSessionService Playback

<div class="page-wrap">
    <div class="page-header">
        <div class="header-left">
            <button class="back-btn" @onclick="GoBack" title="Back to programs">← Programs</button>
            <h1>@(_program?.Name ?? "Loading…")</h1>
            @if (!string.IsNullOrWhiteSpace(_program?.Description))
            {
                <p class="subtitle">@_program.Description</p>
            }
        </div>
        <button class="btn-primary" @onclick="CreateNew" disabled="@(_program is null)">+ New meditation</button>
    </div>

    @if (_loading)
    {
        <div class="empty-state">Loading…</div>
    }
    else if (!_meditations.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">◎</div>
            <p>No meditations in this program yet.</p>
            <button class="btn-primary" @onclick="CreateNew">+ New meditation</button>
        </div>
    }
    else
    {
        <div class="meditation-grid">
            @foreach (var m in _meditations)
            {
                var isPlayingThis = Playback.CurrentMeditationId == m.Id;
                var isLoadingThis = _loadingId == m.Id;
                var fill = isPlayingThis ? OverallFraction() : 0d;
                var dashoffset = RingCircumference - (fill * RingCircumference);

                <div class="meditation-card @(isPlayingThis ? "playing" : "")">
                    <div class="card-header">
                        <div class="card-avatar">
                            <img src="img/meditation-avatar.png" alt="" />
                        </div>
                        <div class="card-meta-rows">
                            <div class="meta-row">
                                <span class="meta-label">TITLE</span>
                                <span class="meta-value meta-title">@m.Title</span>
                            </div>
                            <div class="meta-row">
                                <span class="meta-label">STATUS</span>
                                <span class="meta-value status-@m.Status.ToLower()">@m.Status</span>
                            </div>
                            <div class="meta-row">
                                <span class="meta-label">TYPE</span>
                                @* Kategoria ("TYPE" w UI, żeby label był krótki i pasował do kolumny).
                                   Brak kategorii → szary placeholder — lepsze niż pusty wiersz, bo
                                   zachowuje się stała wysokość karty. *@
                                @if (!string.IsNullOrEmpty(m.CategoryName))
                                {
                                    <span class="meta-value category-chip">@m.CategoryName</span>
                                }
                                else
                                {
                                    <span class="meta-value category-chip empty">Uncategorized</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(m.Description))
                            {
                                <div class="card-desc">@m.Description</div>
                            }
                        </div>
                    </div>

                    <div class="gold-bar">
                        @foreach (var cat in LayerCategories)
                        {
                            var count = m.TracksByLayerType.TryGetValue(cat.Key, out var c) ? c : 0;
                            <div class="gold-bar-item" title="@cat.Key">
                                <i class="@cat.Icon gold-bar-icon" aria-hidden="true"></i>
                                <span class="gold-bar-count">@count</span>
                            </div>
                        }
                    </div>

                    <div class="card-footer-meta">@FormatDuration(m.DurationMs) · @m.CreatedAt.ToString("MMM d, yyyy")</div>

                    <div class="card-actions">
                        <div class="play-btn-ring" title="@(isPlayingThis ? "Stop" : "Play")">
                            <svg class="play-ring" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                                <circle class="ring-bg" cx="16" cy="16" r="13" />
                                <circle class="ring-fill @(isPlayingThis ? "active" : "")"
                                        cx="16" cy="16" r="13"
                                        style="stroke-dasharray: @RingCircumferenceCss; stroke-dashoffset: @dashoffset.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                            </svg>
                            <button class="play-btn @(isPlayingThis ? "playing" : "")"
                                    @onclick="() => TogglePlay(m)"
                                    disabled="@isLoadingThis">
                                @if (isLoadingThis)
                                {
                                    <span class="spinner"></span>
                                }
                                else if (isPlayingThis)
                                {
                                    <text>◼</text>
                                }
                                else
                                {
                                    <text>▶</text>
                                }
                            </button>
                        </div>
                        <button class="edit-btn" @onclick="() => Open(m.Id)" title="Edit">✎</button>
                        <button class="delete-btn" @onclick="() => ConfirmDelete(m)" title="Delete">
                            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_creating)
{
    <div class="modal-backdrop">
        <div class="modal">
            <h2>New meditation</h2>
            <div class="field">
                <label>Title</label>
                <input @bind="_newTitle" placeholder="e.g. Morning calm" />
            </div>
            <div class="field">
                <label>Category</label>
                @* Dropdown z kategorii usera. Na tej stronie modal pokazuje się
                   po kliku "+ New meditation", więc _categories są już załadowane
                   z OnInitializedAsync. Jeśli lista pusta (bardzo mało prawdopodobne
                   po seedzie, ale user może wszystkie skasować) — pokazujemy link
                   do strony zarządzania zamiast selecta. *@
                @if (_categories.Count == 0)
                {
                    <p class="category-empty-hint">
                        No categories yet. <a href="/categories">Add one</a> to tag this meditation.
                    </p>
                }
                else
                {
                    <select @bind="_newCategoryId">
                        <option value="">— Select —</option>
                        @foreach (var c in _categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                }
            </div>
            <div class="field">
                <label>Description (optional)</label>
                <textarea @bind="_newDesc" placeholder="What is this meditation for?" rows="3"></textarea>
            </div>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="() => _creating = false">Cancel</button>
                <button class="btn-primary" @onclick="ConfirmCreate"
                        disabled="@(string.IsNullOrWhiteSpace(_newTitle) || string.IsNullOrEmpty(_newCategoryId))">Create</button>
            </div>
        </div>
    </div>
}

@if (_deletingMeditation is not null)
{
    <div class="modal-backdrop">
        <div class="modal">
            <h2>Delete meditation?</h2>
            <p class="modal-desc">
                <strong>@_deletingMeditation.Title</strong> and all its tracks will be permanently removed. This cannot be undone.
            </p>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="() => _deletingMeditation = null" disabled="@_deleting">Cancel</button>
                <button class="btn-danger" @onclick="ConfirmDeleteExecute" disabled="@_deleting">
                    @(_deleting ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ProgramDetailDto? _program;
    private List<MeditationSummaryDto> _meditations = [];
    private List<CategorySummaryDto> _categories = [];
    private bool _loading = true, _creating;
    private string _newTitle = "", _newDesc = "";
    // String zamiast Guid?, bo <select> @bind'uje string; parsujemy w ConfirmCreate.
    // "" oznacza "nic nie wybrano" → przycisk Create pozostaje disabled.
    private string _newCategoryId = "";
    private Guid? _loadingId;
    private MeditationSummaryDto? _deletingMeditation;
    private bool _deleting;

    // Ikony zgodne z edytorem (LayerDisplayOrder) — Text → Music → Nature → Fx.
    private static readonly (string Key, string Icon)[] LayerCategories =
    {
        ("Text", "fa-solid fa-comment"),
        ("Music", "fa-solid fa-music"),
        ("Nature", "fa-solid fa-wind"),
        ("Fx", "fa-solid fa-drum"),
    };

    private const double RingCircumference = 81.68;
    private const string RingCircumferenceCss = "81.68";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!await Auth.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login");
            return;
        }

        await LoadAsync();

        Playback.OnChanged += HandlePlaybackChanged;
    }

    // Odświeżenie przy zmianie parametru Id — jeżeli user kliknie inny program
    // bez unmount komponentu (teoretycznie NavLinkiem, ale mamy tylko głęboki link).
    protected override async Task OnParametersSetAsync()
    {
        if (_program is not null && _program.Id != Id)
        {
            _loading = true;
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        try
        {
            // Program + kategorie ładujemy równolegle — oba są niezależne od
            // siebie, oba potrzebne przed wyświetleniem strony (modal "New
            // meditation" chce listę kategorii na starcie).
            var programTask = ProgramSvc.GetByIdAsync(Id);
            var categoriesTask = CategorySvc.GetAllAsync();
            await Task.WhenAll(programTask, categoriesTask);
            _program = await programTask;
            _meditations = _program?.Meditations.ToList() ?? [];
            _categories = await categoriesTask ?? [];
        }
        catch (HttpRequestException)
        {
            await Auth.LogoutAsync();
            Nav.NavigateTo("/login");
            return;
        }
        _loading = false;
    }

    private void HandlePlaybackChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Playback.OnChanged -= HandlePlaybackChanged;
    }

    private double OverallFraction()
    {
        var p = Playback.GetOverallProgress();
        return p.Total > 0 ? Math.Clamp(p.Current / p.Total, 0, 1) : 0;
    }

    private async Task TogglePlay(MeditationSummaryDto m)
    {
        if (Playback.CurrentMeditationId == m.Id)
        {
            await Playback.StopAsync();
            return;
        }
        if (_loadingId is not null) return;
        _loadingId = m.Id;
        try
        {
            var detail = await MeditationSvc.GetByIdAsync(m.Id);
            if (detail is null) return;
            await Playback.StartAsync(detail);
        }
        catch { }
        finally
        {
            _loadingId = null;
        }
    }

    private void CreateNew()
    {
        _newTitle = "";
        _newDesc = "";
        _newCategoryId = "";
        _creating = true;
    }

    private async Task ConfirmCreate()
    {
        // ProgramId to bieżący `Id` strony — medytacja trafia do tego konkretnego
        // programu. Po utworzeniu nawigujemy do edytora z kontekstem programu
        // (`?program=…`), żeby Back z edytora wracał tutaj, nie do listy programów.
        // CategoryId parsujemy z string'a (@bind selecta) — przycisk Create jest
        // disabled dopóki user nie wybierze, więc tu pole zawsze ma poprawny guid.
        Guid? categoryId = Guid.TryParse(_newCategoryId, out var parsed) ? parsed : null;
        var result = await MeditationSvc.CreateAsync(Id, _newTitle.Trim(), _newDesc.Trim(), categoryId);
        if (result is not null) Nav.NavigateTo($"/meditations/{result.Id}?program={Id}");
    }

    private void Open(Guid id) => Nav.NavigateTo($"/meditations/{id}?program={Id}");

    private void GoBack() => Nav.NavigateTo("/");

    private void ConfirmDelete(MeditationSummaryDto m) => _deletingMeditation = m;

    private async Task ConfirmDeleteExecute()
    {
        if (_deletingMeditation is null || _deleting) return;
        _deleting = true;
        var id = _deletingMeditation.Id;
        try
        {
            if (Playback.CurrentMeditationId == id)
            {
                await Playback.StopAsync();
            }

            var response = await MeditationSvc.DeleteAsync(id);
            if (response.IsSuccessStatusCode)
            {
                _meditations.RemoveAll(x => x.Id == id);
                _deletingMeditation = null;
            }
        }
        finally
        {
            _deleting = false;
        }
    }

    private static string FormatDuration(int ms) =>
        ms == 0 ? "No duration set" : $"{ms / 60000}m {(ms % 60000) / 1000}s";
}

<style>
    .page-wrap { padding: 32px 40px; max-width: 1200px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px; gap: 16px; }
    .header-left { min-width: 0; flex: 1; }
    .back-btn {
        background: none; border: none; cursor: pointer;
        font-size: 13px; color: var(--color-text-secondary);
        padding: 0 0 8px; margin: 0;
    }
    .back-btn:hover { color: var(--color-text-primary); }
    h1 { font-size: 22px; font-weight: 500; margin: 0 0 4px; }
    .subtitle { color: var(--color-text-secondary); font-size: 14px; margin: 0; }

    .meditation-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(500px, 1fr)); gap: 20px; }
    .meditation-card {
        position: relative;
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 10px;
        padding: 24px 28px 68px;
        overflow: hidden;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .meditation-card:hover { border-color: var(--color-border-secondary); }
    .meditation-card.playing { border-color: var(--color-text-info); }

    .card-header { display: flex; gap: 22px; align-items: flex-start; margin-bottom: 20px; }
    .card-avatar { width: 104px; height: 104px; flex-shrink: 0; }
    .card-avatar img { width: 100%; height: 100%; display: block; }

    .card-meta-rows { display: flex; flex-direction: column; gap: 6px; min-width: 0; flex: 1; }
    .meta-row { display: flex; align-items: baseline; gap: 10px; min-width: 0; }
    .meta-label {
        font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
        color: var(--color-text-tertiary);
        flex-shrink: 0;
        min-width: 48px;
    }
    .meta-value {
        font-size: 14px; color: var(--color-text-primary);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .meta-title { font-weight: 500; font-size: 15px; }
    .status-draft { color: var(--color-text-warning); font-weight: 500; }
    .status-published { color: var(--color-text-success); font-weight: 500; }
    .status-archived { color: var(--color-text-tertiary); font-weight: 500; }

    /* Chip kategorii — lekki pill w kolorze akcentu (gold), spójny z paletą
       złotego paska, ale mniejszy i dyskretniejszy (to meta-row, nie CTA). */
    .category-chip {
        display: inline-flex; align-items: center;
        padding: 2px 10px;
        border-radius: 20px;
        background: rgba(197, 165, 108, 0.15);
        color: #8B6F3E;
        font-size: 12px; font-weight: 500;
        letter-spacing: 0.01em;
        max-width: 100%;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .category-chip.empty {
        background: var(--color-background-secondary);
        color: var(--color-text-tertiary);
        font-style: italic;
        font-weight: 400;
    }

    .card-desc {
        font-size: 13px; color: var(--color-text-secondary);
        margin: 8px 0 0; line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .gold-bar {
        display: flex; justify-content: space-around; align-items: center;
        background: #C5A56C;
        padding: 18px 28px;
        /* Ujemne marginesy boczne wyciągają pasek na pełną szerokość karty
           (negują padding 28px). Margin-bottom:0 — odstęp do przycisków jest
           w całości obsługiwany przez padding-bottom:68px, dzięki czemu
           przestrzeń nad i pod przyciskami jest symetryczna (po 14px). */
        margin: 0 -28px;
    }
    .gold-bar-item {
        display: inline-flex; align-items: center; gap: 10px;
        color: #FFFFFF;
        font-size: 17px;
        font-weight: 500;
    }
    .gold-bar-icon { font-size: 20px; line-height: 1; }
    .gold-bar-count {
        font-variant-numeric: tabular-nums;
        min-width: 14px; text-align: center;
    }

    .card-footer-meta {
        position: absolute;
        bottom: 22px; left: 28px;
        font-size: 12px; color: var(--color-text-tertiary);
        max-width: calc(100% - 180px);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    .card-actions {
        position: absolute;
        bottom: 14px; right: 20px;
        display: flex; align-items: center; gap: 6px;
    }

    .play-btn-ring {
        position: relative;
        width: 40px; height: 40px;
        display: inline-flex; align-items: center; justify-content: center;
    }
    .play-ring {
        position: absolute; inset: 0;
        width: 40px; height: 40px;
        transform: rotate(-90deg);
        pointer-events: none;
    }
    .play-ring .ring-bg {
        fill: none;
        stroke: var(--color-border-tertiary);
        stroke-width: 2.5;
        opacity: 0.5;
    }
    .play-ring .ring-fill {
        fill: none;
        stroke: var(--color-text-info);
        stroke-width: 2.5;
        stroke-linecap: round;
        transition: stroke-dashoffset 0.18s linear;
    }
    .play-ring .ring-fill.active { opacity: 1; }

    .play-btn {
        position: relative;
        width: 28px; height: 28px;
        border: none; background: transparent;
        color: var(--color-text-secondary);
        border-radius: 50%;
        cursor: pointer;
        font-size: 13px; line-height: 1;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0;
        transition: background 0.15s, color 0.15s;
    }
    .play-btn:hover:not(:disabled) {
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
    }
    .play-btn.playing {
        background: var(--color-text-info);
        color: var(--color-background-primary);
    }
    .play-btn:disabled { cursor: default; opacity: 0.7; }

    .edit-btn, .delete-btn {
        width: 36px; height: 36px;
        border: none; background: transparent;
        color: var(--color-text-secondary);
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px; line-height: 1;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0;
        transition: background 0.15s, color 0.15s;
    }
    .edit-btn:hover {
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
    }
    .delete-btn { font-size: 18px; }
    .delete-btn:hover {
        background: var(--color-background-danger, rgba(220, 53, 69, 0.12));
        color: var(--color-text-danger, #dc3545);
    }

    .spinner {
        width: 14px; height: 14px;
        border: 1.8px solid currentColor;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        display: inline-block;
    }
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .empty-state { text-align: center; padding: 80px 20px; color: var(--color-text-secondary); }
    .empty-icon { font-size: 36px; margin-bottom: 12px; }

    .modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex; align-items: center; justify-content: center;
        z-index: 100;
    }
    .modal {
        background: var(--color-background-primary);
        border-radius: 12px; padding: 32px;
        width: 440px; max-width: 90vw;
    }
    .modal h2 { font-size: 18px; font-weight: 500; margin: 0 0 16px; }
    .modal-desc { font-size: 14px; color: var(--color-text-secondary); margin: 0 0 24px; line-height: 1.5; }
    .modal-desc strong { color: var(--color-text-primary); font-weight: 500; }
    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .field label { font-size: 13px; color: var(--color-text-secondary); }
    .field input, .field textarea, .field select {
        padding: 9px 12px; border-radius: 6px; font-size: 14px;
        border: 1px solid var(--color-border-secondary);
        background: var(--color-background-secondary);
        color: var(--color-text-primary); resize: vertical;
    }
    .field select { appearance: auto; padding-right: 28px; }

    .category-empty-hint {
        font-size: 13px;
        color: var(--color-text-secondary);
        margin: 0;
        padding: 9px 12px;
        border-radius: 6px;
        background: var(--color-background-secondary);
    }
    .category-empty-hint a { color: var(--color-text-info); text-decoration: none; }
    .category-empty-hint a:hover { text-decoration: underline; }
    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 24px; }
    .btn-primary {
        padding: 9px 18px; border-radius: 6px;
        background: var(--color-text-primary); color: var(--color-background-primary);
        border: none; font-size: 14px; font-weight: 500; cursor: pointer;
    }
    .btn-primary:disabled { opacity: 0.4; cursor: default; }
    .btn-secondary {
        padding: 9px 18px; border-radius: 6px;
        background: transparent; color: var(--color-text-secondary);
        border: 1px solid var(--color-border-secondary);
        font-size: 14px; cursor: pointer;
    }
    .btn-secondary:disabled { opacity: 0.4; cursor: default; }
    .btn-danger {
        padding: 9px 18px; border-radius: 6px;
        background: var(--color-text-danger, #dc3545); color: #fff;
        border: none; font-size: 14px; font-weight: 500; cursor: pointer;
    }
    .btn-danger:disabled { opacity: 0.6; cursor: default; }
</style>
