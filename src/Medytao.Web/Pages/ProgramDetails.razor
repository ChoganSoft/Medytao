    .edit-btn:hover, .duplicate-btn:hover:not(:disabled) {
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
    }
    /* Kosz fa-trash i kopia fa-clone mają większą wagę wizualną niż unicode
