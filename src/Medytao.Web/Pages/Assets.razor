@* Pojedyncza strona obsługująca cztery URL-e — po jednym per warstwa.
   `/assets` (bez segmentu) wpada tu też dla wstecznej kompatybilności i
   przekierowuje do `/assets/music`. Każdy link w menu ma swój route,
   więc NavLink ten aktywny podświetla się sam. *@
@page "/assets"
@page "/assets/{Layer}"
@inject AssetService AssetSvc
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="page-wrap">
    <div class="page-header">
        <div>
            <h1>@_currentLayer library</h1>
            <p class="subtitle">@SubtitleFor(_currentLayer)</p>
        </div>
        <label class="btn-primary">
            + Upload @_currentLayer.ToLowerInvariant()
            <InputFile @ref="_fileInput" OnChange="HandleUpload" accept="@AcceptForLayer(_currentLayer)" multiple style="display:none" />
        </label>
    </div>

    @if (_uploading)
    {
        <div class="upload-banner">Uploading…</div>
    }

    @if (_loading)
    {
        <div class="empty-state">Loading…</div>
    }
    else if (!_assets.Any())
    {
        <div class="empty-state">
            <i class="empty-icon @IconForLayer(_currentLayer)" aria-hidden="true"></i>
            <p>No @_currentLayer.ToLowerInvariant() assets yet. Upload files to start building sessions.</p>
        </div>
    }
    else
    {
        <div class="asset-grid">
            @foreach (var a in _assets)
            {
                <div class="asset-card @(a.IsShared ? "shared" : "")">
                    <i class="asset-icon @IconForLayer(a.LayerType)" aria-hidden="true"></i>
                    <div class="asset-details">
                        <div class="asset-name" title="@a.FileName">@a.FileName</div>
                        <div class="asset-meta">
                            @a.LayerType · @FormatSize(a.SizeBytes)
                            @if (a.DurationMs.HasValue) { <text> · @FormatDuration(a.DurationMs.Value)</text> }
                        </div>
                    </div>
                    <AudioPreviewButton Url="@a.Url" />

                    @if (a.IsMine)
                    {
                        @* Toggle widoczności — tylko dla swoich zasobów. Klik flipuje
                           IsShared po stronie backendu i podmienia wpis na liście.
                           Tytuł wyjaśnia stan i co się stanie po kliku. *@
                        <button class="share-toggle @(a.IsShared ? "on" : "off")"
                                @onclick="() => ToggleSharing(a)"
                                disabled="@(_pendingShareId == a.Id)"
                                title="@(a.IsShared ? "Shared with everyone — click to make private" : "Private — click to share with everyone")">
                            <i class="@(a.IsShared ? "fa-solid fa-globe" : "fa-solid fa-lock")" aria-hidden="true"></i>
                            <span>@(a.IsShared ? "Shared" : "Private")</span>
                        </button>
                        <button class="delete-btn" @onclick="() => Delete(a.Id)" title="Delete">
                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        </button>
                    }
                    else
                    {
                        @* Cudzy shared albo zasób systemowy — read-only badge. *@
                        <span class="shared-badge" title="Available to everyone">
                            <i class="fa-solid fa-globe" aria-hidden="true"></i> Shared
                        </span>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    // Route param. Domyślnie pusty (gdy ktoś wszedł na /assets bez segmentu) —
    // wtedy w OnParametersSet redirektujemy do /assets/music. Walidacja: jeśli
    // segment jest spoza listy znanych warstw, też wpada w redirect (cicha
    // sanityzacja, brak 404 — to nie jest publiczny URL na zewnątrz).
    [Parameter] public string? Layer { get; set; }

    private static readonly string[] KnownLayers = ["Music", "Nature", "Text", "Fx"];

    private List<Medytao.Shared.Models.AssetDto> _assets = [];
    private bool _loading = true, _uploading;
    private string _currentLayer = "Music";

    // Id zasobu, którego toggle aktualnie czeka na backend — disable'ujemy
    // przycisk, żeby user nie spamował klikiem zanim API odpowie.
    private Guid? _pendingShareId;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!await Auth.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login");
            return;
        }
    }

    // Reagujemy na każdą zmianę route-paramu (kliknięcie w NavLinka innej warstwy
    // bez przeładowania komponentu). NormalizeLayer rzuca null, jeśli segment
    // jest nieznany albo pusty — wtedy redirect na default. Po normalizacji
    // ładujemy listę tylko gdy faktycznie zmienił się _currentLayer.
    protected override async Task OnParametersSetAsync()
    {
        var normalized = NormalizeLayer(Layer);
        if (normalized is null)
        {
            // Segment pusty/niepasujący — domyślnie kierujemy do Music.
            // forceLoad: false, bo i tak SPA, oszczędzamy pełny reload.
            Nav.NavigateTo("/assets/music", forceLoad: false, replace: true);
            return;
        }

        if (normalized == _currentLayer && !_loading) return;

        _currentLayer = normalized;
        await LoadAssetsAsync();
    }

    private async Task LoadAssetsAsync()
    {
        _loading = true;
        _assets = await AssetSvc.GetByLayerAsync(_currentLayer) ?? [];
        _loading = false;
    }

    // Ref do natywnego <input type="file"> wewnątrz <InputFile>. Potrzebne JS-owi
    // (medytaoUpload.readDurationMs) żeby dostać się do File-objektu i odczytać
    // duration przez tymczasowe <audio>.
    private InputFile? _fileInput;

    private async Task HandleUpload(InputFileChangeEventArgs e)
    {
        _uploading = true;
        var files = e.GetMultipleFiles(10).ToList();
        for (var i = 0; i < files.Count; i++)
        {
            var file = files[i];
            // Auto-detect duration PRZED uploadem — jeśli się uda, przekazujemy
            // do API żeby Asset.DurationMs trafił do bazy od razu. Failsafe:
            // gdy JS interop rzuci albo plik nieczytelny, ms zostaje null
            // i flow działa jak wcześniej (preloadDurations potem dopnie wartość).
            int? durationMs = null;
            if (_fileInput is not null)
            {
                try
                {
                    var ms = await JS.InvokeAsync<int?>("medytaoUpload.readDurationMs", _fileInput.Element, i);
                    if (ms.HasValue && ms.Value > 0) durationMs = ms.Value;
                }
                catch { /* ignorujemy — fallback do null */ }
            }

            await using var stream = file.OpenReadStream(maxAllowedSize: 500 * 1024 * 1024);
            // LayerType uploadu = aktualnie otwarta strona. Backend tworzy
            // odpowiednią podklasę (MusicAsset/NatureAsset/...).
            var result = await AssetSvc.UploadAsync(stream, file.Name, file.ContentType, _currentLayer, durationMs);
            if (result is not null) _assets.Insert(0, result);
        }
        _uploading = false;
    }

    private async Task Delete(Guid id)
    {
        await AssetSvc.DeleteAsync(id);
        _assets.RemoveAll(a => a.Id == id);
    }

    private async Task ToggleSharing(Medytao.Shared.Models.AssetDto current)
    {
        if (_pendingShareId is not null) return;
        _pendingShareId = current.Id;
        try
        {
            var updated = await AssetSvc.SetSharingAsync(current.Id, !current.IsShared);
            if (updated is not null)
            {
                // Backend zwrócił świeży DTO z poprawnymi flagami (IsShared
                // zaktualizowane, IsMine = true). Podmieniamy wpis w miejscu
                // zachowując kolejność listy.
                var idx = _assets.FindIndex(a => a.Id == current.Id);
                if (idx >= 0) _assets[idx] = updated;
            }
        }
        finally
        {
            _pendingShareId = null;
        }
    }

    // Case-insensitive match po znanych warstwach. Zwracamy kanoniczną pisownię
    // ("Music"/"Nature"/"Text"/"Fx") niezależnie od tego co user wpisał w URL.
    private static string? NormalizeLayer(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        return KnownLayers.FirstOrDefault(l =>
            string.Equals(l, raw, StringComparison.OrdinalIgnoreCase));
    }

    private static string SubtitleFor(string layer) => layer switch
    {
        "Music" => "Background music and ambient tracks",
        "Nature" => "Forest, rain, waves and other nature sounds",
        "Text" => "Spoken word recordings (your own narration)",
        "Fx" => "Gongs, bells and sound accents",
        _ => "Audio files for this layer"
    };

    // TextAsset dziś trzyma plik audio (lektor nagrany przez usera). Gdy w
    // przyszłości warstwa Text dostanie generowany TTS (skrypt + voice ID),
    // tu rozszerzymy MIME-y dla zakładki Text.
    private static string AcceptForLayer(string layer) => "audio/*";

    // Klasy Font Awesome — te same co w sidebarze i na gold-barze karty
    // medytacji (Pages/Index.razor → LayerCategories oraz Components/Layers/
    // LayerPanel.razor → LayerIcon). Spójna semantyka: Music = nuta, Nature =
    // wiatr, Text = dymek wypowiedzi, Fx = bęben.
    private static string IconForLayer(string layer) => layer switch
    {
        "Music" => "fa-solid fa-music",
        "Nature" => "fa-solid fa-wind",
        "Text" => "fa-solid fa-comment",
        "Fx" => "fa-solid fa-drum",
        _ => "fa-solid fa-circle"
    };

    private static string FormatSize(long bytes) =>
        bytes < 1024 * 1024 ? $"{bytes / 1024}KB" : $"{bytes / (1024 * 1024.0):F1}MB";
    private static string FormatDuration(int ms) =>
        $"{ms / 60000}:{(ms % 60000 / 1000):D2}";
}

<style>
    .page-wrap { padding: 32px 40px; max-width: 1100px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px; }
    h1 { font-size: 22px; font-weight: 500; margin: 0 0 4px; }
    .subtitle { color: var(--color-text-secondary); font-size: 14px; margin: 0; }
    .btn-primary { padding: 9px 18px; border-radius: 6px; background: var(--color-text-primary); color: var(--color-background-primary); border: none; font-size: 14px; font-weight: 500; cursor: pointer; }

    .upload-banner { padding: 10px 16px; background: var(--color-background-info); color: var(--color-text-info); border-radius: 6px; margin-bottom: 16px; font-size: 13px; }

    .asset-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
    .asset-card { display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: var(--color-background-primary); border: 1px solid var(--color-border-tertiary); border-radius: 8px; }
    .asset-card.shared { background: var(--color-background-secondary); }
    .asset-icon { font-size: 20px; color: var(--color-text-secondary); }
    .asset-details { flex: 1; min-width: 0; }
    .asset-name { font-size: 13px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .asset-meta { font-size: 11px; color: var(--color-text-tertiary); margin-top: 2px; }
    /* fa-trash 12px — drobna ikonka w wierszu asset-card razem z share-toggle
       (też kompaktowy element). 18px Unicode-x był wizualnie cięższy niż
       resz wiersza, kosz przy tym samym rozmiarze byłby przesadny. */
    .delete-btn { background: none; border: none; font-size: 12px; color: var(--color-text-tertiary); cursor: pointer; padding: 4px 6px; border-radius: 4px; }
    .delete-btn:hover { color: var(--color-text-danger); background: var(--color-background-danger); }

    /* Toggle udostępniania własnego zasobu. Stan "off" (private) — neutralny,
       wyciszony; "on" (shared) — wyróżniony info-color, żeby od razu było
       widać, które rzeczy user już wystawił innym. */
    .share-toggle {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 11px;
        background: transparent;
        border: 1px solid var(--color-border-tertiary);
        border-radius: 4px;
        padding: 4px 8px;
        color: var(--color-text-secondary);
        cursor: pointer;
        transition: color .15s, border-color .15s, background .15s;
    }
    .share-toggle:hover { color: var(--color-text-primary); border-color: var(--color-border-secondary); }
    .share-toggle.on { color: var(--color-text-info); border-color: var(--color-border-info); background: var(--color-background-info); }
    .share-toggle:disabled { opacity: 0.5; cursor: wait; }

    /* Read-only marker dla cudzych shared / seedów systemowych. Wizualnie
       podobny do toggle'a w stanie "shared", ale bez tła i pointer-cursora. */
    .shared-badge {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 11px;
        color: var(--color-text-tertiary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 4px;
        padding: 4px 8px;
    }

    .empty-state { text-align: center; padding: 80px 20px; color: var(--color-text-secondary); }
    .empty-icon { font-size: 36px; margin-bottom: 12px; }
</style>
