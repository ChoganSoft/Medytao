@page "/"
@implements IDisposable
@inject MeditationService MeditationSvc
@inject AuthService Auth
@inject NavigationManager Nav
@inject PlaybackSessionService Playback

<div class="page-wrap">
    <div class="page-header">
        <div>
            <h1>My meditations</h1>
            <p class="subtitle">Build and manage your meditation sessions</p>
        </div>
        <button class="btn-primary" @onclick="CreateNew">+ New meditation</button>
    </div>

    @if (_loading)
    {
        <div class="empty-state">Loading…</div>
    }
    else if (!_meditations.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">◎</div>
            <p>No meditations yet. Create your first one.</p>
            <button class="btn-primary" @onclick="CreateNew">+ New meditation</button>
        </div>
    }
    else
    {
        <div class="meditation-grid">
            @foreach (var m in _meditations)
            {
                var isPlayingThis = Playback.CurrentMeditationId == m.Id;
                var isLoadingThis = _loadingId == m.Id;
                var fill = isPlayingThis ? OverallFraction() : 0d;
                var dashoffset = RingCircumference - (fill * RingCircumference);

                <div class="meditation-card @(isPlayingThis ? "playing" : "")">
                    <div class="card-header">
                        <div class="card-avatar">
                            @* Avatar 1:1 z designu — plik PNG leży w wwwroot/img/.
                               Dekoracyjny, więc alt="". *@
                            <img src="img/meditation-avatar.png" alt="" />
                        </div>
                        <div class="card-meta-rows">
                            <div class="meta-row">
                                <span class="meta-label">TITLE</span>
                                <span class="meta-value meta-title">@m.Title</span>
                            </div>
                            <div class="meta-row">
                                <span class="meta-label">STATUS</span>
                                <span class="meta-value status-@m.Status.ToLower()">@m.Status</span>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(m.Description))
                    {
                        <div class="card-desc">@m.Description</div>
                    }

                    @* Złoty pasek z 4 kategoriami warstw (Music / Nature / Text / Fx).
                       Kolejność hard-coded — LayerType enum żyje w Medytao.Domain i Web
                       dostaje tylko stringi w TracksByLayerType. Jeśli backend doda nowy
                       LayerType, karta po cichu go pominie (ale trzeba będzie dodać ikonę). *@
                    <div class="gold-bar">
                        @foreach (var cat in LayerCategories)
                        {
                            var count = m.TracksByLayerType.TryGetValue(cat.Key, out var c) ? c : 0;
                            <div class="gold-bar-item" title="@cat.Key">
                                <span class="gold-bar-icon">@cat.Icon</span>
                                <span class="gold-bar-count">@count</span>
                            </div>
                        }
                    </div>

                    <div class="card-footer-meta">@FormatDuration(m.DurationMs) · @m.CreatedAt.ToString("MMM d, yyyy")</div>

                    <div class="card-actions">
                        @* Play zawsze widoczny — DurationMs w Summary DTO jest wyliczany tylko gdy
                           ktoś wywoła UpdateMeditationCommand (czego frontend obecnie nie robi),
                           więc w praktyce zawsze ==0 i ukrywanie buttona ukrywa go wszędzie.
                           Klik na medytację bez warstw: StartAsync guard layers.Length==0 → no-op.
                           TODO: gdy backend zacznie liczyć duration z warstw — przywrócić warunek. *@
                        <div class="play-btn-ring" title="@(isPlayingThis ? "Stop" : "Play")">
                            <svg class="play-ring" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                                <circle class="ring-bg" cx="16" cy="16" r="13" />
                                <circle class="ring-fill @(isPlayingThis ? "active" : "")"
                                        cx="16" cy="16" r="13"
                                        style="stroke-dasharray: @RingCircumferenceCss; stroke-dashoffset: @dashoffset.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)" />
                            </svg>
                            <button class="play-btn @(isPlayingThis ? "playing" : "")"
                                    @onclick="() => TogglePlay(m)"
                                    disabled="@isLoadingThis">
                                @if (isLoadingThis)
                                {
                                    <span class="spinner"></span>
                                }
                                else if (isPlayingThis)
                                {
                                    <text>◼</text>
                                }
                                else
                                {
                                    <text>▶</text>
                                }
                            </button>
                        </div>
                        <button class="edit-btn" @onclick="() => Open(m.Id)" title="Edit">✎</button>
                        <button class="delete-btn" @onclick="() => ConfirmDelete(m)" title="Delete">×</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_creating)
{
    <div class="modal-backdrop">
        <div class="modal">
            <h2>New meditation</h2>
            <div class="field">
                <label>Title</label>
                <input @bind="_newTitle" placeholder="e.g. Morning calm" />
            </div>
            <div class="field">
                <label>Description (optional)</label>
                <textarea @bind="_newDesc" placeholder="What is this meditation for?" rows="3"></textarea>
            </div>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="() => _creating = false">Cancel</button>
                <button class="btn-primary" @onclick="ConfirmCreate" disabled="@(string.IsNullOrWhiteSpace(_newTitle))">Create</button>
            </div>
        </div>
    </div>
}

@if (_deletingMeditation is not null)
{
    <div class="modal-backdrop">
        <div class="modal">
            <h2>Delete meditation?</h2>
            <p class="modal-desc">
                <strong>@_deletingMeditation.Title</strong> and all its tracks will be permanently removed. This cannot be undone.
            </p>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="() => _deletingMeditation = null" disabled="@_deleting">Cancel</button>
                <button class="btn-danger" @onclick="ConfirmDeleteExecute" disabled="@_deleting">
                    @(_deleting ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<MeditationSummaryDto> _meditations = [];
    private bool _loading = true, _creating;
    private string _newTitle = "", _newDesc = "";

    // Id medytacji, dla której trwa fetch detailu przed StartAsync — blokuje podwójne kliknięcia
    // i pozwala wyrysować spinner. Null gdy nic nie ładujemy.
    private Guid? _loadingId;

    // Modal usuwania — trzyma referencję do DTO żeby pokazać tytuł w pytaniu.
    // _deleting blokuje przyciski modalu na czas requestu (user nie zdąży kliknąć dwa razy).
    private MeditationSummaryDto? _deletingMeditation;
    private bool _deleting;

    // Kolejność i ikony warstw na złotym pasku. Stringi-klucze pasują do enum
    // LayerType.ToString() serializowanego w MeditationSummaryDto.TracksByLayerType.
    // Ikony zsynchronizowane z Components/Layers/LayerPanel.razor.
    private static readonly (string Key, string Icon)[] LayerCategories =
    {
        ("Music", "♪"),
        ("Nature", "〜"),
        ("Text", "≡"),
        ("Fx", "✦"),
    };

    // 2 * π * r, gdzie r = 13. Obwód okręgu ringa w px — używany jako stroke-dasharray
    // i baza do wyliczenia dashoffset z fraction.
    private const double RingCircumference = 81.68;
    private const string RingCircumferenceCss = "81.68";

    protected override async Task OnInitializedAsync()
    {
        // Wczytaj token z localStorage i przypnij do HttpClient
        await Auth.InitializeAsync();

        // Jeśli nie ma ważnego tokenu — idź na login
        if (!await Auth.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            _meditations = await MeditationSvc.GetAllAsync() ?? [];
        }
        catch (HttpRequestException)
        {
            // Token wygasł lub nieautoryzowany — wyczyść i wyślij na login
            await Auth.LogoutAsync();
            Nav.NavigateTo("/login");
            return;
        }
        _loading = false;

        // Ring + ikonka play muszą się odświeżać na każdy tick PlaybackSession.
        Playback.OnChanged += HandlePlaybackChanged;
    }

    private void HandlePlaybackChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Playback.OnChanged -= HandlePlaybackChanged;
    }

    private double OverallFraction()
    {
        var p = Playback.GetOverallProgress();
        return p.Total > 0 ? Math.Clamp(p.Current / p.Total, 0, 1) : 0;
    }

    private async Task TogglePlay(MeditationSummaryDto m)
    {
        // Klik na aktualnie graną → po prostu stop.
        if (Playback.CurrentMeditationId == m.Id)
        {
            await Playback.StopAsync();
            return;
        }

        // Inna medytacja → pobierz detail (Summary nie ma warstw) i wystartuj.
        // StartAsync sam zatrzyma poprzednią sesję, więc nie trzeba ręcznego Stop.
        if (_loadingId is not null) return; // Zignoruj dopóki trwa poprzedni fetch.
        _loadingId = m.Id;
        try
        {
            var detail = await MeditationSvc.GetByIdAsync(m.Id);
            if (detail is null) return;
            await Playback.StartAsync(detail);
        }
        catch
        {
            // Zjadamy błąd sieciowy — user zobaczy po prostu że nic się nie stało.
            // W przyszłości można dodać toast.
        }
        finally
        {
            _loadingId = null;
        }
    }

    private void CreateNew() { _newTitle = ""; _newDesc = ""; _creating = true; }

    private async Task ConfirmCreate()
    {
        var result = await MeditationSvc.CreateAsync(_newTitle.Trim(), _newDesc.Trim());
        if (result is not null) Nav.NavigateTo($"/meditations/{result.Id}");
    }

    private void Open(Guid id) => Nav.NavigateTo($"/meditations/{id}");

    private void ConfirmDelete(MeditationSummaryDto m) => _deletingMeditation = m;

    private async Task ConfirmDeleteExecute()
    {
        if (_deletingMeditation is null || _deleting) return;
        _deleting = true;
        var id = _deletingMeditation.Id;
        try
        {
            // Jeśli usuwamy medytację, która właśnie gra — najpierw stop, inaczej
            // audio leciałoby dalej a karta zniknęła (i user nie ma jak zatrzymać).
            if (Playback.CurrentMeditationId == id)
            {
                await Playback.StopAsync();
            }

            var response = await MeditationSvc.DeleteAsync(id);
            if (response.IsSuccessStatusCode)
            {
                _meditations.RemoveAll(x => x.Id == id);
                _deletingMeditation = null;
            }
            // 4xx/5xx — zostaw modal otwarty, user może spróbować jeszcze raz.
            // TODO: toast/error info, na razie cicho.
        }
        finally
        {
            _deleting = false;
        }
    }

    private static string FormatDuration(int ms) =>
        ms == 0 ? "No duration set" : $"{ms / 60000}m {(ms % 60000) / 1000}s";
}

<style>
    .page-wrap { padding: 32px 40px; max-width: 1200px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px; }
    h1 { font-size: 22px; font-weight: 500; margin: 0 0 4px; }
    .subtitle { color: var(--color-text-secondary); font-size: 14px; margin: 0; }

    /* Szersza karta żeby pomieściła header avatar+meta oraz złoty pasek. */
    .meditation-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(440px, 1fr)); gap: 20px; }
    .meditation-card {
        position: relative;
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 10px;
        /* Extra padding-bottom żeby stopka z przyciskami nie zachodziła na footer-meta. */
        padding: 20px 20px 56px;
        /* overflow: hidden żeby złoty pasek rozciągnięty ujemnym margin-x
           nie wyszedł poza zaokrąglone rogi karty. */
        overflow: hidden;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .meditation-card:hover { border-color: var(--color-border-secondary); }
    .meditation-card.playing { border-color: var(--color-text-info); }

    /* ── Header: avatar + meta rows ───────────────────────────────────────── */
    .card-header { display: flex; gap: 16px; align-items: center; margin-bottom: 14px; }
    .card-avatar { width: 64px; height: 64px; flex-shrink: 0; }
    .card-avatar img { width: 100%; height: 100%; display: block; }

    .card-meta-rows { display: flex; flex-direction: column; gap: 6px; min-width: 0; flex: 1; }
    .meta-row { display: flex; align-items: baseline; gap: 10px; min-width: 0; }
    .meta-label {
        font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
        color: var(--color-text-tertiary);
        flex-shrink: 0;
        min-width: 48px;
    }
    .meta-value {
        font-size: 14px; color: var(--color-text-primary);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .meta-title { font-weight: 500; font-size: 15px; }
    /* Kolorowe badge dla statusu — pozostawiam semantykę z poprzedniej wersji
       (draft=warning, published=success, archived=muted). */
    .status-draft { color: var(--color-text-warning); font-weight: 500; }
    .status-published { color: var(--color-text-success); font-weight: 500; }
    .status-archived { color: var(--color-text-tertiary); font-weight: 500; }

    /* ── Description ──────────────────────────────────────────────────────── */
    .card-desc {
        font-size: 13px; color: var(--color-text-secondary);
        margin: 0 0 14px; line-height: 1.5;
        /* Ograniczamy do 2 linii żeby karty zostały mniej więcej równe. */
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* ── Złoty pasek z 4 kategoriami warstw ───────────────────────────────── */
    /* Ujemny margin-x == padding karty (20px) — pasek sięga lewej i prawej
       krawędzi karty. overflow: hidden na .meditation-card klipuje rogi. */
    .gold-bar {
        display: flex; justify-content: space-around; align-items: center;
        background: #C5A56C;
        padding: 12px 20px;
        margin: 0 -20px 16px;
    }
    .gold-bar-item {
        display: inline-flex; align-items: center; gap: 6px;
        color: #FFFFFF;
        font-size: 14px;
        font-weight: 500;
    }
    .gold-bar-icon { font-size: 16px; line-height: 1; }
    .gold-bar-count {
        font-variant-numeric: tabular-nums;
        min-width: 14px; text-align: center;
    }

    /* ── Footer meta (duration + date) ────────────────────────────────────── */
    .card-footer-meta {
        position: absolute;
        bottom: 18px; left: 20px;
        font-size: 12px; color: var(--color-text-tertiary);
        /* Rezerwujemy miejsce na 3 przyciski po prawej (~108px + bufor). */
        max-width: calc(100% - 140px);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    /* ── Akcje w prawym dolnym rogu: play+ring, edit, delete ──────────────── */
    .card-actions {
        position: absolute;
        bottom: 12px; right: 12px;
        display: flex; align-items: center; gap: 4px;
    }

    /* Wrapper trzyma ring i button jeden na drugim — struktura zerżnięta z
       AudioPreviewButton, patrz Components/Shared/AudioPreviewButton.razor. */
    .play-btn-ring {
        position: relative;
        width: 32px; height: 32px;
        display: inline-flex; align-items: center; justify-content: center;
    }
    .play-ring {
        position: absolute; inset: 0;
        width: 32px; height: 32px;
        transform: rotate(-90deg); /* 0% od góry, nie od 3 o'clock */
        pointer-events: none;
    }
    .play-ring .ring-bg {
        fill: none;
        stroke: var(--color-border-tertiary);
        stroke-width: 2.5;
        opacity: 0.5;
    }
    .play-ring .ring-fill {
        fill: none;
        stroke: var(--color-text-info);
        stroke-width: 2.5;
        stroke-linecap: round;
        transition: stroke-dashoffset 0.18s linear;
    }
    .play-ring .ring-fill.active { opacity: 1; }

    .play-btn {
        position: relative; /* zapewnia stacking nad SVG mimo że SVG jest absolute */
        width: 22px; height: 22px;
        border: none; background: transparent;
        color: var(--color-text-secondary);
        border-radius: 50%;
        cursor: pointer;
        font-size: 10px; line-height: 1;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0;
        transition: background 0.15s, color 0.15s;
    }
    .play-btn:hover:not(:disabled) {
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
    }
    .play-btn.playing {
        background: var(--color-text-info);
        color: var(--color-background-primary);
    }
    .play-btn:disabled { cursor: default; opacity: 0.7; }

    .edit-btn, .delete-btn {
        width: 28px; height: 28px;
        border: none; background: transparent;
        color: var(--color-text-secondary);
        border-radius: 50%;
        cursor: pointer;
        font-size: 14px; line-height: 1;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0;
        transition: background 0.15s, color 0.15s;
    }
    .edit-btn:hover {
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
    }
    /* Delete ma większą ikonę (×) i czerwony hover żeby odróżnić destructive action. */
    .delete-btn { font-size: 18px; }
    .delete-btn:hover {
        background: var(--color-background-danger, rgba(220, 53, 69, 0.12));
        color: var(--color-text-danger, #dc3545);
    }

    /* Spinner dla stanu loading (między klikiem a rozpoczęciem odtwarzania,
       kiedy dociągamy MeditationDetailDto z API). */
    .spinner {
        width: 10px; height: 10px;
        border: 1.5px solid currentColor;
        border-top-color: transparent;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
        display: inline-block;
    }
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .empty-state { text-align: center; padding: 80px 20px; color: var(--color-text-secondary); }
    .empty-icon { font-size: 36px; margin-bottom: 12px; }

    .modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex; align-items: center; justify-content: center;
        z-index: 100;
    }
    .modal {
        background: var(--color-background-primary);
        border-radius: 12px; padding: 32px;
        width: 440px; max-width: 90vw;
    }
    .modal h2 { font-size: 18px; font-weight: 500; margin: 0 0 16px; }
    .modal-desc { font-size: 14px; color: var(--color-text-secondary); margin: 0 0 24px; line-height: 1.5; }
    .modal-desc strong { color: var(--color-text-primary); font-weight: 500; }
    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .field label { font-size: 13px; color: var(--color-text-secondary); }
    .field input, .field textarea {
        padding: 9px 12px; border-radius: 6px; font-size: 14px;
        border: 1px solid var(--color-border-secondary);
        background: var(--color-background-secondary);
        color: var(--color-text-primary); resize: vertical;
    }
    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 24px; }
    .btn-primary {
        padding: 9px 18px; border-radius: 6px;
        background: var(--color-text-primary); color: var(--color-background-primary);
        border: none; font-size: 14px; font-weight: 500; cursor: pointer;
    }
    .btn-primary:disabled { opacity: 0.4; cursor: default; }
    .btn-secondary {
        padding: 9px 18px; border-radius: 6px;
        background: transparent; color: var(--color-text-secondary);
        border: 1px solid var(--color-border-secondary);
        font-size: 14px; cursor: pointer;
    }
    .btn-secondary:disabled { opacity: 0.4; cursor: default; }
    .btn-danger {
        padding: 9px 18px; border-radius: 6px;
        background: var(--color-text-danger, #dc3545); color: #fff;
        border: none; font-size: 14px; font-weight: 500; cursor: pointer;
    }
    .btn-danger:disabled { opacity: 0.6; cursor: default; }
</style>
