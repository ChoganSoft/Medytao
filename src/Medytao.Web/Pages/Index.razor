@page "/"
@inject ProgramService ProgramSvc
@inject AuthService Auth
@inject NavigationManager Nav

<div class="page-wrap">
    <div class="page-header">
        <div>
            <h1>My programs</h1>
            <p class="subtitle">Organise meditations into programs</p>
        </div>
        <button class="btn-primary" @onclick="CreateNew">+ New program</button>
    </div>

    @if (_loading)
    {
        <div class="empty-state">Loading…</div>
    }
    else if (!_programs.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">◎</div>
            <p>No programs yet. Create your first one.</p>
            <button class="btn-primary" @onclick="CreateNew">+ New program</button>
        </div>
    }
    else
    {
        <div class="program-grid">
            @foreach (var p in _programs)
            {
                <div class="program-card">
                    <div class="card-header">
                        @* Karta programu — bez awatara (decyzja designu).
                           Meta-kolumna zajmuje całą szerokość. *@
                        <div class="card-meta-rows">
                            <div class="meta-row">
                                <span class="meta-label">TITLE</span>
                                <span class="meta-value meta-title">@p.Name</span>
                            </div>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div class="card-desc">@p.Description</div>
                            }
                        </div>
                    </div>

                    @* Złoty pasek — lista nazw medytacji w programie (zamiast
                       samego licznika, żeby user widział skład programu bez
                       wchodzenia w szczegóły). Tytuły oddzielone separatorem
                       "•", cała linia obcinana ellipsis jeśli nie mieści się
                       w karcie; pełna lista widoczna w tooltipie. Pusta lista
                       → placeholder "No meditations yet". Ikonę "list" z FA
                       zostawiamy dla symetrii z kartą medytacji. *@
                    <div class="gold-bar">
                        <div class="gold-bar-item" title="@(p.MeditationTitles.Count == 0 ? "No meditations" : string.Join(", ", p.MeditationTitles))">
                            <i class="fa-solid fa-list gold-bar-icon" aria-hidden="true"></i>
                            @if (p.MeditationTitles.Count == 0)
                            {
                                <span class="gold-bar-empty">No meditations yet</span>
                            }
                            else
                            {
                                <span class="gold-bar-titles">@string.Join("  •  ", p.MeditationTitles)</span>
                            }
                        </div>
                        @* Enter button przeniesiony z card-actions na prawą stronę
                           gold-bara — primary action wbudowana w pasek tytułów,
                           a nie schowana w dolnym rogu obok edit/delete. Białe kółko
                           ze złotą strzałką (odwrotny kontrast niż reszta paska). *@
                        <button class="enter-btn" @onclick="() => Enter(p.Id)" title="Open program">
                            <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                        </button>
                    </div>

                    <div class="card-footer-meta">Created @p.CreatedAt.ToString("MMM d, yyyy")</div>

                    <div class="card-actions">
                        @* Edit — ołówek, sama nazwa + opis. Delete — FA xmark.
                           Enter wcześniej był tutaj, teraz siedzi na gold-bar. *@
                        <button class="edit-btn" @onclick="() => BeginEdit(p)" title="Edit">✎</button>
                        <button class="delete-btn" @onclick="() => ConfirmDelete(p)" title="Delete">
                            <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_creating)
{
    <div class="modal-backdrop">
        <div class="modal">
            <h2>New program</h2>
            <div class="field">
                <label>Name</label>
                <input @bind="_formName" placeholder="e.g. Morning routine" />
            </div>
            <div class="field">
                <label>Description (optional)</label>
                <textarea @bind="_formDesc" placeholder="What is this program for?" rows="3"></textarea>
            </div>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="() => _creating = false" disabled="@_saving">Cancel</button>
                <button class="btn-primary" @onclick="ConfirmCreate" disabled="@(string.IsNullOrWhiteSpace(_formName) || _saving)">
                    @(_saving ? "Creating…" : "Create")
                </button>
            </div>
        </div>
    </div>
}

@if (_editing is not null)
{
    <div class="modal-backdrop">
        <div class="modal">
            <h2>Edit program</h2>
            <div class="field">
                <label>Name</label>
                <input @bind="_formName" />
            </div>
            <div class="field">
                <label>Description (optional)</label>
                <textarea @bind="_formDesc" rows="3"></textarea>
            </div>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CancelEdit" disabled="@_saving">Cancel</button>
                <button class="btn-primary" @onclick="ConfirmEdit" disabled="@(string.IsNullOrWhiteSpace(_formName) || _saving)">
                    @(_saving ? "Saving…" : "Save")
                </button>
            </div>
        </div>
    </div>
}

@if (_deleting is not null)
{
    <div class="modal-backdrop">
        <div class="modal">
            <h2>Delete program?</h2>
            <p class="modal-desc">
                <strong>@_deleting.Name</strong> will be permanently removed.
                @if (_deleting.MeditationTitles.Count > 0)
                {
                    <text> Meditations that exist only in this program will also be deleted (@_deleting.MeditationTitles.Count in total). This cannot be undone.</text>
                }
                else
                {
                    <text> This cannot be undone.</text>
                }
            </p>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="() => _deleting = null" disabled="@_saving">Cancel</button>
                <button class="btn-danger" @onclick="ConfirmDeleteExecute" disabled="@_saving">
                    @(_saving ? "Deleting…" : "Delete")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ProgramSummaryDto> _programs = [];
    private bool _loading = true;
    private bool _creating, _saving;
    private ProgramSummaryDto? _editing;
    private ProgramSummaryDto? _deleting;

    // Wspólny bufor formularza dla create i edit — pojedyncza para pól
    // wystarczy, bo tylko jeden modal może być otwarty naraz.
    private string _formName = "";
    private string _formDesc = "";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!await Auth.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            _programs = await ProgramSvc.GetAllAsync() ?? [];
        }
        catch (HttpRequestException)
        {
            await Auth.LogoutAsync();
            Nav.NavigateTo("/login");
            return;
        }
        _loading = false;
    }

    private void CreateNew()
    {
        _formName = "";
        _formDesc = "";
        _creating = true;
    }

    private async Task ConfirmCreate()
    {
        if (_saving || string.IsNullOrWhiteSpace(_formName)) return;
        _saving = true;
        try
        {
            var result = await ProgramSvc.CreateAsync(_formName.Trim(), _formDesc.Trim());
            if (result is not null)
            {
                _programs.Add(result);
                _creating = false;
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void BeginEdit(ProgramSummaryDto p)
    {
        _editing = p;
        _formName = p.Name;
        _formDesc = p.Description ?? "";
    }

    private void CancelEdit() { _editing = null; }

    private async Task ConfirmEdit()
    {
        if (_editing is null || _saving || string.IsNullOrWhiteSpace(_formName)) return;
        _saving = true;
        try
        {
            var updated = await ProgramSvc.UpdateAsync(_editing.Id, _formName.Trim(), _formDesc.Trim());
            if (updated is not null)
            {
                // Wstaw updated w miejsce starej wersji, zachowując kolejność.
                var idx = _programs.FindIndex(x => x.Id == updated.Id);
                if (idx >= 0) _programs[idx] = updated;
                _editing = null;
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void ConfirmDelete(ProgramSummaryDto p) => _deleting = p;

    private async Task ConfirmDeleteExecute()
    {
        if (_deleting is null || _saving) return;
        _saving = true;
        var id = _deleting.Id;
        try
        {
            var response = await ProgramSvc.DeleteAsync(id);
            if (response.IsSuccessStatusCode)
            {
                _programs.RemoveAll(x => x.Id == id);
                _deleting = null;
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void Enter(Guid id) => Nav.NavigateTo($"/programs/{id}");
}

<style>
    .page-wrap { padding: 32px 40px; max-width: 1200px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px; }
    h1 { font-size: 22px; font-weight: 500; margin: 0 0 4px; }
    .subtitle { color: var(--color-text-secondary); font-size: 14px; margin: 0; }

    /* Siatka programów — identyczna do meditation-grid (minmax 500px) dla
       spójności wizualnej między widokami. */
    .program-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(500px, 1fr)); gap: 20px; }
    .program-card {
        position: relative;
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 10px;
        padding: 24px 28px 68px;
        overflow: hidden;
        transition: border-color 0.15s;
    }
    .program-card:hover { border-color: var(--color-border-secondary); }

    /* Bez awatara — meta-rows sama wypełnia wiersz. */
    .card-header { display: flex; margin-bottom: 20px; }
    .card-meta-rows { display: flex; flex-direction: column; gap: 6px; min-width: 0; flex: 1; }
    .meta-row { display: flex; align-items: baseline; gap: 10px; min-width: 0; }
    .meta-label {
        font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
        color: var(--color-text-tertiary);
        flex-shrink: 0;
        min-width: 48px;
    }
    .meta-value {
        font-size: 14px; color: var(--color-text-primary);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .meta-title { font-weight: 500; font-size: 15px; }

    .card-desc {
        font-size: 13px; color: var(--color-text-secondary);
        margin: 8px 0 0; line-height: 1.5;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Złoty pasek — identyczna paleta co karta medytacji. Pojedyncza pozycja
       z ikoną + listą tytułów medytacji w programie. Lista może być długa,
       więc cała linia jest obcinana ellipsis (nowrap); pełną treść user
       zobaczy w tooltipie (title na .gold-bar-item). */
    .gold-bar {
        display: flex; align-items: center;
        gap: 16px;
        background: #C5A56C;
        padding: 14px 28px;
        /* Ujemne marginesy boczne wyciągają pasek na pełną szerokość karty
           (negują padding 28px). Margin-bottom:0 — odstęp do przycisków jest
           w całości obsługiwany przez padding-bottom:68px, dzięki czemu
           przestrzeń nad i pod przyciskami jest symetryczna (po 14px).
           Gap 16px zostawia miejsce między listą tytułów a enter-btn po prawej. */
        margin: 0 -28px;
        min-width: 0;
    }
    .gold-bar-item {
        display: flex; align-items: center; gap: 12px;
        color: #FFFFFF;
        font-size: 14px;
        font-weight: 500;
        min-width: 0;
        flex: 1;
    }
    .gold-bar-icon { font-size: 20px; line-height: 1; flex-shrink: 0; }
    .gold-bar-titles {
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        min-width: 0;
        letter-spacing: 0.01em;
    }
    .gold-bar-empty {
        opacity: 0.78;
        font-style: italic;
        font-weight: 400;
    }

    .card-footer-meta {
        position: absolute;
        bottom: 22px; left: 28px;
        font-size: 12px; color: var(--color-text-tertiary);
        max-width: calc(100% - 160px);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    .card-actions {
        position: absolute;
        bottom: 14px; right: 20px;
        display: flex; align-items: center; gap: 6px;
    }

    /* Enter button — siedzi na gold-bar (z prawej). Białe kółko ze złotą
       strzałką = odwrócenie kontrastu reszty paska, dzięki czemu primary
       action wybija się jako "guzik na pasku" zamiast zlewać z tłem.
       flex-shrink:0 zabezpiecza przed rozjazdem gdy gold-bar-item ma długą
       listę tytułów. */
    .enter-btn {
        width: 36px; height: 36px;
        border: none; cursor: pointer;
        border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        background: #FFFFFF;
        color: #C5A56C;
        font-size: 14px; line-height: 1;
        padding: 0;
        flex-shrink: 0;
        transition: transform 0.15s, box-shadow 0.15s;
    }
    .enter-btn:hover {
        transform: scale(1.08);
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.18);
    }

    .edit-btn, .delete-btn {
        width: 36px; height: 36px;
        border: none; background: transparent;
        color: var(--color-text-secondary);
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px; line-height: 1;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0;
        transition: background 0.15s, color 0.15s;
    }
    /* Kosz fa-trash ma większą wagę wizualną niż unicode pencil w edit-btn,
       więc na tym samym font-size 18px wyglądał za duży obok ołówka.
       Zmniejszamy delete do 14px — optycznie zrównuje się z edit. */
    .delete-btn { font-size: 14px; }
    .edit-btn:hover {
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
    }
    .delete-btn:hover {
        background: var(--color-background-danger, rgba(220, 53, 69, 0.12));
        color: var(--color-text-danger, #dc3545);
    }

    .empty-state { text-align: center; padding: 80px 20px; color: var(--color-text-secondary); }
    .empty-icon { font-size: 36px; margin-bottom: 12px; }

    .modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex; align-items: center; justify-content: center;
        z-index: 100;
    }
    .modal {
        background: var(--color-background-primary);
        border-radius: 12px; padding: 32px;
        width: 440px; max-width: 90vw;
    }
    .modal h2 { font-size: 18px; font-weight: 500; margin: 0 0 16px; }
    .modal-desc { font-size: 14px; color: var(--color-text-secondary); margin: 0 0 24px; line-height: 1.5; }
    .modal-desc strong { color: var(--color-text-primary); font-weight: 500; }
    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .field label { font-size: 13px; color: var(--color-text-secondary); }
    .field input, .field textarea {
        padding: 9px 12px; border-radius: 6px; font-size: 14px;
        border: 1px solid var(--color-border-secondary);
        background: var(--color-background-secondary);
        color: var(--color-text-primary); resize: vertical;
    }
    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 24px; }
    .btn-primary {
        padding: 9px 18px; border-radius: 6px;
        background: var(--color-text-primary); color: var(--color-background-primary);
        border: none; font-size: 14px; font-weight: 500; cursor: pointer;
    }
    .btn-primary:disabled { opacity: 0.4; cursor: default; }
    .btn-secondary {
        padding: 9px 18px; border-radius: 6px;
        background: transparent; color: var(--color-text-secondary);
        border: 1px solid var(--color-border-secondary);
        font-size: 14px; cursor: pointer;
    }
    .btn-secondary:disabled { opacity: 0.4; cursor: default; }
    .btn-danger {
        padding: 9px 18px; border-radius: 6px;
        background: var(--color-text-danger, #dc3545); color: #fff;
        border: none; font-size: 14px; font-weight: 500; cursor: pointer;
    }
    .btn-danger:disabled { opacity: 0.6; cursor: default; }
</style>
