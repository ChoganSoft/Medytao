@page "/meditations/{Id:guid}"
@implements IDisposable
@inject MeditationService MeditationSvc
@inject AuthService Auth
@inject NavigationManager Nav
@inject PlaybackSessionService PlaybackSession

@if (_meditation is null)
{
    <div class="loading">Loading meditation…</div>
}
else
{
    <div class="editor-shell">
        <!-- Top bar -->
        <div class="editor-topbar">
            <button class="back-btn" @onclick="GoBack">← Back</button>
            <div class="editor-title-wrap">
                <span class="editor-title">@_meditation.Title</span>
                <span class="status-badge @_meditation.Status.ToLower()">@_meditation.Status</span>
            </div>
            <div class="topbar-actions">
                @if (_meditation.Status == "Draft")
                {
                    <button class="btn-secondary" @onclick="Publish">Publish</button>
                }
                <button class="btn-primary play-toggle @(PlaybackSession.IsPlaying ? "playing" : "")"
                        @onclick="TogglePlayback"
                        disabled="@(!HasAnyTracks)">
                    @(PlaybackSession.IsPlaying ? "◼ Stop" : "▶ Play")
                </button>
            </div>
        </div>

        <!-- Four layer canvas -->
        <div class="canvas-area">
            @foreach (var layer in _meditation.Layers.OrderBy(l => l.Type))
            {
                <LayerPanel
                    Layer="layer"
                    OnLayerChanged="HandleLayerChanged"
                    OnOpenAssetPicker="() => OpenAssetPicker(layer.Id)" />
            }
        </div>
    </div>

    <!-- Asset picker modal -->
    @if (_assetPickerLayerId.HasValue)
    {
        <AssetPickerModal
            OnPick="HandleAssetPicked"
            OnClose="() => _assetPickerLayerId = null" />
    }
}

@code {
    [Parameter] public Guid Id { get; set; }
    private MeditationDetailDto? _meditation;
    private Guid? _assetPickerLayerId;

    private bool HasAnyTracks =>
        _meditation is not null && _meditation.Layers.Any(l => l.Tracks.Any());

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!await Auth.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login");
            return;
        }
        _meditation = await MeditationSvc.GetByIdAsync(Id);
        PlaybackSession.OnChanged += HandleSessionChanged;
    }

    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    private void GoBack() => Nav.NavigateTo("/");

    private async Task Publish()
    {
        await MeditationSvc.PublishAsync(Id);
        _meditation = await MeditationSvc.GetByIdAsync(Id);
    }

    private async Task TogglePlayback()
    {
        if (_meditation is null) return;
        if (PlaybackSession.IsPlaying)
        {
            await PlaybackSession.StopAsync();
        }
        else
        {
            await PlaybackSession.StartAsync(_meditation);
        }
    }

    private void OpenAssetPicker(Guid layerId) => _assetPickerLayerId = layerId;

    private async Task HandleAssetPicked(Guid assetId)
    {
        if (_assetPickerLayerId is null) return;
        await MeditationSvc.AddTrackAsync(_assetPickerLayerId.Value, assetId);
        _meditation = await MeditationSvc.GetByIdAsync(Id);
        _assetPickerLayerId = null;
    }

    private async Task HandleLayerChanged()
    {
        _meditation = await MeditationSvc.GetByIdAsync(Id);
        StateHasChanged();
    }

    public void Dispose()
    {
        PlaybackSession.OnChanged -= HandleSessionChanged;
        // Sesja playbacku jest scoped (singleton w WASM) — nie zatrzymujemy jej
        // tutaj, żeby nawigacja do innego widoku jej nie ubiła. Jeśli user
        // chce ciszy, klika Stop.
        // W praktyce i tak Dispose wołamy tylko przy przejściu gdzie indziej.
    }
}

<style>
    .editor-shell { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

    .editor-topbar {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 24px;
        background: var(--color-background-primary);
        border-bottom: 1px solid var(--color-border-tertiary);
        flex-shrink: 0;
    }

    .back-btn {
        background: none; border: none; cursor: pointer;
        font-size: 14px; color: var(--color-text-secondary);
        padding: 4px 0;
    }
    .back-btn:hover { color: var(--color-text-primary); }

    .editor-title-wrap { display: flex; align-items: center; gap: 10px; flex: 1; }
    .editor-title { font-size: 16px; font-weight: 500; }

    .status-badge {
        font-size: 11px; font-weight: 500;
        padding: 2px 8px; border-radius: 20px;
        text-transform: uppercase; letter-spacing: 0.04em;
    }
    .status-badge.draft { background: var(--color-background-warning); color: var(--color-text-warning); }
    .status-badge.published { background: var(--color-background-success); color: var(--color-text-success); }

    .topbar-actions { display: flex; gap: 8px; }

    .canvas-area {
        flex: 1; overflow-y: auto;
        padding: 24px;
        display: flex; flex-direction: column; gap: 16px;
    }

    .loading { display: flex; align-items: center; justify-content: center; height: 100vh; color: var(--color-text-secondary); }

    .btn-primary {
        padding: 8px 16px; border-radius: 6px;
        background: var(--color-text-primary); color: var(--color-background-primary);
        border: none; font-size: 13px; font-weight: 500; cursor: pointer;
    }
    .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-primary.play-toggle.playing {
        background: var(--color-text-info);
    }
    .btn-secondary {
        padding: 8px 16px; border-radius: 6px;
        background: transparent; color: var(--color-text-secondary);
        border: 1px solid var(--color-border-secondary);
        font-size: 13px; cursor: pointer;
    }
</style>
