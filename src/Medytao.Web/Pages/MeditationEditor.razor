@page "/meditations/{Id:guid}"
@implements IDisposable
@inject MeditationService MeditationSvc
@inject AuthService Auth
@inject NavigationManager Nav
@inject PlaybackSessionService PlaybackSession

@if (_meditation is null)
{
    <div class="loading">Loading session…</div>
}
else
{
    <div class="editor-shell">
        <!-- Top bar -->
        <div class="editor-topbar">
            <button class="back-btn" @onclick="GoBack">← Back</button>
            <div class="editor-title-wrap">
                @* Click-to-edit tytułu sesji. Span pokazuje wartość, klik
                   otwiera input z bieżącą wartością. Enter lub blur zapisuje,
                   Escape anuluje. Pusty tytuł po trim → no-op (zostaje
                   poprzednia wartość, tryb edycji się zamyka). *@
                @if (_titleEditing)
                {
                    <input class="editor-title-input"
                           value="@_titleDraft"
                           @oninput="e => _titleDraft = e.Value?.ToString() ?? string.Empty"
                           @onblur="SaveTitle"
                           @onkeydown="OnTitleKeyDown"
                           autofocus />
                }
                else
                {
                    <span class="editor-title editable"
                          @onclick="BeginTitleEdit"
                          title="Click to edit">@_meditation.Title</span>
                }
                <span class="status-badge @_meditation.Status.ToLower()">@_meditation.Status</span>
            </div>
            <div class="topbar-actions">
                @if (_meditation.Status == "Draft")
                {
                    <button class="btn-secondary" @onclick="Publish">Publish</button>
                }
                @* Główny przycisk to toggle Play/Pause (z dodatkowym stanem
                   "Resume" gdy sesja jest spauzowana). Stop jest osobnym
                   przyciskiem obok — zawsze w layoucie, żeby UI nie skakało
                   przy zmianach stanu, a sterujemy tylko enabled/disabled. *@
                <button class="btn-primary play-toggle @(PlaybackSession.IsPlaying ? "playing" : "")"
                        @onclick="TogglePlayback"
                        disabled="@(!HasAnyTracks)">
                    @if (PlaybackSession.IsPlaying)
                    {
                        <span>⏸ Pause</span>
                    }
                    else if (PlaybackSession.IsPaused)
                    {
                        <span>▶ Resume</span>
                    }
                    else
                    {
                        <span>▶ Play</span>
                    }
                </button>
                <button class="btn-secondary stop-btn"
                        @onclick="StopPlayback"
                        disabled="@(!PlaybackSession.IsActive)"
                        title="Stop playback">
                    ◼ Stop
                </button>
            </div>
        </div>

        @* Master timeline. Zegar po lewej (elapsed/total), seekbar zajmuje
           pozostałą szerokość, drag = wizualny preview, release = faktyczny
           seek przez PlaybackSession. Pasek widoczny zawsze gdy są tracki —
           nawet zanim user kliknie Play, żeby mógł zobaczyć skalę czasu
           medytacji i zaplanować future-feature time-anchored triggery. *@
        @if (HasAnyTracks)
        {
            var totalMs = ComputeTotalDurationMs();
            var displayMs = _seekDragMs ?? PlaybackSession.ElapsedMs;
            var fillPct = totalMs > 0 ? Math.Clamp(displayMs / totalMs, 0, 1) * 100 : 0;
            <div class="editor-timeline">
                <span class="timeline-time">
                    @FormatMs(displayMs) <span class="timeline-time-sep">/</span> @FormatMs(totalMs)
                </span>
                @* @key na inkrementującą wartość totalMs/1000 (nie na float żeby
                   tick zegara — gdzie totalMs się nie zmienia — nie powodował
                   re-create co render). Wymusza Blazor do dropowania starego
                   <input> i tworzenia świeżego, gdy totalMs zmieni się na inną
                   wartość. Bez tego diff atrybutu `max` na żywym sliderze
                   bywał ignorowany przez przeglądarkę. *@
                @* fill ze precyzją F2 (np. "23.45%") zamiast cast na int.
                   Native thumb porusza się z pełną precyzją na podstawie
                   atrybutu value, a fill (CSS gradient) z casted-int skakał
                   co całe procenty — przy 60s medytacji to ~600ms na 1%,
                   więc thumb wyprzedzał kolorowy pasek o 2-3 ticki timera. *@
                <input type="range" min="0" max="@totalMs.ToString(System.Globalization.CultureInfo.InvariantCulture)" step="100"
                       @key="(int)(totalMs / 1000)"
                       value="@displayMs.ToString("0", System.Globalization.CultureInfo.InvariantCulture)"
                       @oninput="e => OnSeekDrag(double.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                       @onchange="e => OnSeekRelease(double.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                       class="medytao-slider timeline-slider"
                       style="--slider-fill: @fillPct.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"
                       title="Drag to seek; release to jump audio" />
            </div>
        }

        <!-- Four layer canvas -->
        <div class="canvas-area">
            @* Kolejność wyświetlania warstw ustalona designowo: Text → Music → Nature → Fx.
               Ta sama sekwencja leży w Pages/Index.razor (LayerCategories) dla
               spójności z gold-barem na kartach. Jeśli backend doda nowy LayerType
               nieobecny w LayerDisplayOrder — wyląduje na końcu. *@
            @foreach (var layer in _meditation.Layers.OrderBy(l => LayerOrderKey(l.Type)))
            {
                <LayerPanel
                    Layer="layer"
                    OnLayerChanged="HandleLayerChanged"
                    OnOpenAssetPicker="() => OpenAssetPicker(layer.Id, layer.Type)" />
            }
        </div>
    </div>

    <!-- Asset picker modal -->
    @if (_assetPickerLayerId.HasValue)
    {
        <AssetPickerModal
            LayerType="@_assetPickerLayerType"
            OnPick="HandleAssetPicked"
            OnClose="ClosePicker" />
    }
}

@code {
    [Parameter] public Guid Id { get; set; }
    private MeditationDetailDto? _meditation;
    // Para (id, type) warstwy, dla której otworzyliśmy picker. Type idzie do
    // AssetPickerModal, żeby filtrował zasoby po LayerType i uploadem trafiał
    // do właściwej podklasy Asset.
    private Guid? _assetPickerLayerId;
    private string _assetPickerLayerType = "Music";

    // Kontekst programu z którego user wszedł do edytora (query string
    // "?program=…"). Używany tylko do decyzji gdzie wrócić po kliku Back —
    // pusto oznacza "wróć do listy programów".
    private Guid? _programContextId;

    // Kolejność wyświetlania warstw w edytorze — zgodna z gold-barem na karcie
    // medytacji (Pages/Index.razor → LayerCategories). Gdyby backend zwrócił
    // typ spoza listy, LayerOrderKey zwraca int.MaxValue → ląduje na końcu.
    private static readonly string[] LayerDisplayOrder = { "Text", "Music", "Nature", "Fx" };
    private static int LayerOrderKey(string type)
    {
        var idx = Array.IndexOf(LayerDisplayOrder, type);
        return idx >= 0 ? idx : int.MaxValue;
    }

    private bool HasAnyTracks =>
        _meditation is not null && _meditation.Layers.Any(l => l.Tracks.Any());

    // Wartość pokazywana podczas drag-u suwaka (preview, audio nie skacze).
    // null = brak drag-u, wyświetlamy realny PlaybackSession.ElapsedMs.
    // Czyszczone w OnSeekRelease (gdy user puści przycisk myszy).
    private double? _seekDragMs;

    // Click-to-edit tytułu. _titleEditing = true → renderujemy input zamiast
    // span, _titleDraft trzyma bieżącą wartość edytowanej kopii. Po Save lub
    // Cancel oba są zerowane (Editing=false, Draft="").
    private bool _titleEditing;
    private string _titleDraft = "";

    // Łączna długość medytacji liczona z warstw. Per-warstwa końcówkę liczymy
    // jako max(seqEnd, scheduledEnd):
    //   - seqEnd = suma duration*loops dla tracków BEZ StartAtMs (sequenced
    //     grają jeden po drugim, kumulują czas).
    //   - scheduledEnd = max(StartAtMs + duration) po trackach z StartAtMs
    //     (każdy ma swój punkt startu, nie kumulują się — track o startAt=20s
    //     i duration=15s kończy się na 35s niezależnie od pozostałych
    //     scheduled w tej samej warstwie).
    // Total medytacji = max po końcówkach warstw. Suwak kończy się dokładnie
    // tam gdzie kończy się audio — bez "estetycznego ogona", bo suwak za
    // końcem nagrania myli usera (klik tam = cisza).
    //
    // Minimum 60s żeby slider miał skalę dla pustej medytacji albo dla
    // medytacji bez metadanych (gdzie wszystkie duration = 0 i jedyne
    // wartości to StartAtMs = 0).
    //
    // Duration tracka czytamy: Asset.DurationMs ?? PlaybackSession.KnownDuration
    // (zaktualizowany przez ReportTrackDuration wywoływany z JS po lazy-fetch
    // metadanych przy starcie sesji).
    private double ComputeTotalDurationMs()
    {
        if (_meditation is null) return 0;
        double maxLayerEnd = 0;
        foreach (var layer in _meditation.Layers)
        {
            double seqEnd = 0;
            double scheduledEnd = 0;
            foreach (var t in layer.Tracks)
            {
                var natural = t.Asset.DurationMs ?? PlaybackSession.KnownDuration(t.Asset.Id) ?? 0;
                // Effective wall-clock duration = naturalna / tempo. Slider Speed
                // (warstwa Text) ustawia rate < 1.0 (wolniej, dłużej fizycznie)
                // lub > 1.0 (szybciej, krócej). Bez tego suwak nie pokrywałby
                // realnego czasu odtwarzania spowolnionych fragmentów narracji.
                var rate = t.PlaybackRate > 0 ? t.PlaybackRate : 1.0f;
                var effective = natural / rate;
                if (t.StartAtMs.HasValue)
                {
                    var endpoint = t.StartAtMs.Value + effective;
                    if (endpoint > scheduledEnd) scheduledEnd = endpoint;
                }
                else if (effective > 0)
                {
                    var loops = t.LoopCount == 0 ? 1 : Math.Max(1, t.LoopCount);
                    seqEnd += effective * (double)loops;
                }
            }
            var layerEnd = Math.Max(seqEnd, scheduledEnd);
            if (layerEnd > maxLayerEnd) maxLayerEnd = layerEnd;
        }
        return maxLayerEnd > 0 ? maxLayerEnd : 60_000;
    }

    private static string FormatMs(double ms)
    {
        if (ms < 0 || double.IsNaN(ms)) ms = 0;
        var total = (int)Math.Floor(ms / 1000);
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!await Auth.IsAuthenticatedAsync())
        {
            Nav.NavigateTo("/login");
            return;
        }

        // Jeżeli wszedłeś z widoku programu, URL ma ?program=<guid> — zapisujemy,
        // żeby Back wrócił do tego samego programu. Brak query = fallback na listę.
        // WASM nie ma QueryHelpers w default assembly reference, więc parsujemy
        // ręcznie (jeden parametr, prosty split na '=').
        var query = Nav.ToAbsoluteUri(Nav.Uri).Query;
        if (!string.IsNullOrEmpty(query))
        {
            // query zaczyna się od '?'
            foreach (var kv in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
            {
                var parts = kv.Split('=', 2);
                if (parts.Length == 2 && parts[0] == "program" && Guid.TryParse(parts[1], out var parsed))
                {
                    _programContextId = parsed;
                    break;
                }
            }
        }

        _meditation = await MeditationSvc.GetByIdAsync(Id);
        PlaybackSession.OnChanged += HandleSessionChanged;

        // Preload metadanych durationMs zaraz po wczytaniu medytacji,
        // żeby skala suwaka była poprawna od razu — bez czekania na
        // pierwszy Play. Każde ReportTrackDuration emituje OnChanged,
        // więc UI samoczynnie się przerenderuje gdy fetche się skończą.
        // Asynchronicznie, nie blokuje renderingu strony.
        if (_meditation is not null)
        {
            _ = PlaybackSession.PreloadDurationsAsync(_meditation);
        }
    }

    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    private void GoBack() =>
        Nav.NavigateTo(_programContextId is { } pid ? $"/programs/{pid}" : "/");

    private async Task Publish()
    {
        await MeditationSvc.PublishAsync(Id);
        _meditation = await MeditationSvc.GetByIdAsync(Id);
    }

    // Click-to-edit tytułu sesji.
    //
    // BeginTitleEdit: kopiujemy aktualny tytuł do _titleDraft (input edytuje
    // kopię, nie oryginał — żeby Escape mógł porzucić zmiany bez Refetch).
    //
    // SaveTitle: trim + walidacja "nieperformatywna" (pusto → no-op, identyczne
    // → no-op) zanim strzelimy HTTP. Refetch pełnego DTO po sukcesie zamiast
    // mutacji lokalnej, bo backend aktualizuje też UpdatedAt i mogą się zmienić
    // pochodne pola. Idempotentne na re-entry przez @onblur w trakcie zapisu —
    // _titleEditing sprawdzamy na początku.
    //
    // CancelTitleEdit: bez HTTP, tylko zamyka tryb edycji.
    private void BeginTitleEdit()
    {
        if (_meditation is null || _titleEditing) return;
        _titleDraft = _meditation.Title;
        _titleEditing = true;
    }

    private async Task SaveTitle()
    {
        if (_meditation is null || !_titleEditing) return;
        _titleEditing = false;
        var trimmed = _titleDraft.Trim();
        _titleDraft = "";
        if (string.IsNullOrEmpty(trimmed) || trimmed == _meditation.Title) return;

        // DurationMs przekazujemy z bieżącego DTO — backend nadpisuje całe
        // pole, więc bez tego stracilibyśmy prepocomputed wartość.
        var updated = await MeditationSvc.UpdateAsync(_meditation.Id, trimmed, _meditation.Description, _meditation.DurationMs);
        if (updated is not null)
        {
            _meditation = await MeditationSvc.GetByIdAsync(Id);
        }
    }

    private void CancelTitleEdit()
    {
        _titleEditing = false;
        _titleDraft = "";
    }

    private async Task OnTitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SaveTitle();
        }
        else if (e.Key == "Escape")
        {
            CancelTitleEdit();
        }
    }

    // Trzy stany toggle'a: gra → pauza, spauzowane → resume, spoczynek → start.
    // Stop jest osobnym przyciskiem (StopPlayback), żeby user nie tracił
    // pozycji przez przypadkowy klik w "główny" guzik.
    private async Task TogglePlayback()
    {
        if (_meditation is null) return;
        if (PlaybackSession.IsPlaying)
        {
            await PlaybackSession.PauseAsync();
        }
        else if (PlaybackSession.IsPaused)
        {
            await PlaybackSession.ResumeAsync();
        }
        else
        {
            await PlaybackSession.StartAsync(_meditation);
        }
    }

    private Task StopPlayback() => PlaybackSession.StopAsync();

    // Drag suwaka: tylko preview wizualny — nic nie ruszamy w audio,
    // żeby przy każdym pikselu drag-u nie restartować sesji. Wartość
    // wyświetlamy przez _seekDragMs zamiast ElapsedMs.
    private void OnSeekDrag(double ms)
    {
        _seekDragMs = ms;
    }

    // Release suwaka: faktyczny seek. Gdy sesja gra → restart przez SeekAsync
    // z nowym startFromMs. Gdy spauzowana → SeekAsync tylko aktualizuje
    // zamrożoną pozycję bez wznawiania (jak w mp3 playerze: scrub w pauzie
    // przesuwa kropkę, ale nie startuje audio). Gdy spoczynek — start od
    // tej pozycji (drag bez Play to też sygnał "graj stąd"). _seekDragMs
    // czyścimy żeby kolejny render wracał do realnego ElapsedMs z service-u.
    private async Task OnSeekRelease(double ms)
    {
        _seekDragMs = null;
        if (_meditation is null) return;
        if (PlaybackSession.IsActive)
        {
            await PlaybackSession.SeekAsync(ms);
        }
        else
        {
            await PlaybackSession.StartAsync(_meditation, ms);
        }
    }

    private void OpenAssetPicker(Guid layerId, string layerType)
    {
        _assetPickerLayerId = layerId;
        _assetPickerLayerType = layerType;
    }

    private void ClosePicker() => _assetPickerLayerId = null;

    private async Task HandleAssetPicked(Guid assetId)
    {
        if (_assetPickerLayerId is null) return;
        await MeditationSvc.AddTrackAsync(_assetPickerLayerId.Value, assetId);
        _meditation = await MeditationSvc.GetByIdAsync(Id);
        _assetPickerLayerId = null;
        // Świeżo dodany track może mieć Asset bez metadanych — preload
        // zaraz, żeby suwak miał właściwą skalę bez czekania na Play.
        if (_meditation is not null)
        {
            _ = PlaybackSession.PreloadDurationsAsync(_meditation);
        }
    }

    private async Task HandleLayerChanged()
    {
        _meditation = await MeditationSvc.GetByIdAsync(Id);
        StateHasChanged();
        // Tracki mogły dojść/odejść/zmienić assety — preload obejmuje
        // nowe i pomija te z już znanym duration (cache w PlaybackSession).
        if (_meditation is not null)
        {
            _ = PlaybackSession.PreloadDurationsAsync(_meditation);
        }
    }

    public void Dispose()
    {
        PlaybackSession.OnChanged -= HandleSessionChanged;
        // Sesja playbacku jest scoped (singleton w WASM) — nie zatrzymujemy jej
        // tutaj, żeby nawigacja do innego widoku jej nie ubiła. Jeśli user
        // chce ciszy, klika Stop.
        // W praktyce i tak Dispose wołamy tylko przy przejściu gdzie indziej.
    }
}

<style>
    .editor-shell { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

    .editor-topbar {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 24px;
        background: var(--color-background-primary);
        border-bottom: 1px solid var(--color-border-tertiary);
        flex-shrink: 0;
    }

    /* Pasek timeline pod topbarem — zegar po lewej, slider zajmuje resztę
       szerokości. Wizualnie subtelne tło (sekundarny), żeby nie konkurować
       z głównym headerem ale wyraźnie odznaczał strefę "narzędzi czasu". */
    .editor-timeline {
        display: flex; align-items: center; gap: 16px;
        padding: 8px 24px;
        background: var(--color-background-secondary);
        border-bottom: 1px solid var(--color-border-tertiary);
        flex-shrink: 0;
    }
    .timeline-time {
        font-size: 13px;
        color: var(--color-text-secondary);
        font-variant-numeric: tabular-nums;
        min-width: 92px; /* "10:00 / 10:00" mieści się stabilnie */
        flex-shrink: 0;
    }
    .timeline-time-sep {
        margin: 0 4px;
        color: var(--color-text-tertiary);
    }
    .timeline-slider { flex: 1; }

    .back-btn {
        background: none; border: none; cursor: pointer;
        font-size: 14px; color: var(--color-text-secondary);
        padding: 4px 0;
    }
    .back-btn:hover { color: var(--color-text-primary); }

    .editor-title-wrap { display: flex; align-items: center; gap: 10px; flex: 1; }
    .editor-title { font-size: 16px; font-weight: 500; }
    /* Klasa .editable dorzucana tylko na "spanie" trybu wyświetlania —
       hover pokazuje że tytuł jest klikalny (delikatne tło + kursor text). */
    .editor-title.editable {
        cursor: text;
        padding: 2px 6px;
        border-radius: 4px;
        transition: background 0.1s;
    }
    .editor-title.editable:hover {
        background: var(--color-background-secondary);
    }
    /* Input dziedziczy wymiary po editor-title (16px / 500), żeby przejście
       span → input było bezszwowe (brak skoku layoutu). Padding/border idą
       w ramach tego samego box-sizingu co padding spana w .editable. */
    .editor-title-input {
        font-size: 16px;
        font-weight: 500;
        font-family: inherit;
        padding: 2px 6px;
        border: 1px solid var(--color-border-info, #4a90e2);
        border-radius: 4px;
        background: var(--color-background-primary);
        color: var(--color-text-primary);
        outline: none;
        min-width: 220px;
    }

    .status-badge {
        font-size: 11px; font-weight: 500;
        padding: 2px 8px; border-radius: 20px;
        text-transform: uppercase; letter-spacing: 0.04em;
    }
    .status-badge.draft { background: var(--color-background-warning); color: var(--color-text-warning); }
    .status-badge.published { background: var(--color-background-success); color: var(--color-text-success); }

    .topbar-actions { display: flex; gap: 8px; }

    .canvas-area {
        flex: 1; overflow-y: auto;
        padding: 24px;
        display: flex; flex-direction: column; gap: 16px;
    }

    .loading { display: flex; align-items: center; justify-content: center; height: 100vh; color: var(--color-text-secondary); }

    .btn-primary {
        padding: 8px 16px; border-radius: 6px;
        background: var(--color-text-primary); color: var(--color-background-primary);
        border: none; font-size: 13px; font-weight: 500; cursor: pointer;
    }
    .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-primary.play-toggle.playing {
        background: var(--color-text-info);
    }
    .btn-secondary {
        padding: 8px 16px; border-radius: 6px;
        background: transparent; color: var(--color-text-secondary);
        border: 1px solid var(--color-border-secondary);
        font-size: 13px; cursor: pointer;
    }
    .btn-secondary:disabled { opacity: 0.4; cursor: not-allowed; }
</style>
