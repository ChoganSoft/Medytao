@using Medytao.Shared.Models
@inject MeditationService MeditationSvc
@inject PlaybackSessionService PlaybackSession

<div class="track-card @(IsExpanded ? "expanded" : "") @(IsCurrent ? "current" : "")">
    <!-- Main row -->
    <div class="track-row" @onclick="ToggleExpand">
        @* draggable=true tylko na uchwycie — to jedyny element, z którego
           startuje reorder. Dzięki temu mousedown na suwakach/inputach nie
           bąbla do żadnego draggable rodzica i kontrolki działają normalnie.
           dragstart/dragend lecą do parenta (LayerPanel) przez callbacki. *@
        <span class="drag-handle"
              draggable="true"
              @onclick:stopPropagation="true"
              @ondragstart="@(async () => await OnDragStartFromHandle.InvokeAsync())"
              @ondragend="@(async () => await OnDragEndFromHandle.InvokeAsync())"
              title="Drag to reorder">⠿</span>

        <AudioPreviewButton Url="@Track.Asset.Url" Volume="_volume" PlaybackRate="_playbackRate" ReverbMix="_reverbMix" />

        <div class="track-info">
            <span class="track-filename">
                @Track.Asset.FileName
                @if (BlocksSequence)
                {
                    <span class="blocks-sequence" title="Loops forever — tracks after this one won't play">∞</span>
                }
            </span>
            @if (Track.Asset.DurationMs.HasValue)
            {
                <span class="track-duration">@FormatDuration(Track.Asset.DurationMs.Value)</span>
            }
        </div>

        <div class="track-quick-controls" @onclick:stopPropagation="true">
            <input type="range" min="0" max="1" step="0.01"
                   value="@_volume.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                   @oninput="e => OnVolumeInput(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   @onchange="e => OnVolumeChange(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   class="medytao-slider vol-slider"
                   style="--slider-fill: @((int)(_volume * 100))%"
                   title="Volume" />
            <span class="vol-value">@((int)(_volume * 100))%</span>

            <div class="loop-control" title="Play N times (0 = loop forever)">
                <span class="loop-icon">⟳</span>
                <input type="number" min="0" max="99" step="1"
                       value="@_loopCount"
                       @onchange="e => OnLoopCountChange(int.Parse(e.Value!.ToString()!))"
                       class="loop-input" />
                @if (_loopCount == 0)
                {
                    <span class="loop-infinity">∞</span>
                }
                else
                {
                    <span class="loop-x">×</span>
                }
            </div>

        </div>

        <button class="remove-btn" @onclick:stopPropagation="true" @onclick="Remove" title="Remove track">×</button>
        <span class="expand-arrow">@(IsExpanded ? "∧" : "∨")</span>
    </div>

    <!-- Expanded controls -->
    @if (IsExpanded)
    {
        <div class="track-detail">
            <div class="detail-row">
                <span class="detail-label">Fade in</span>
                <input type="number" min="0" step="100" @bind="_fadeInMs" class="ms-input" /> ms
            </div>
            <div class="detail-row">
                <span class="detail-label">Fade out</span>
                <input type="number" min="0" step="100" @bind="_fadeOutMs" class="ms-input" /> ms
            </div>
            <div class="detail-row">
                <span class="detail-label">Start offset</span>
                <input type="number" min="0" step="1000" @bind="_startOffsetMs" class="ms-input" /> ms
            </div>
            <div class="detail-row">
                <span class="detail-label">Crossfade to next</span>
                <input type="number" min="0" step="100" @bind="_crossfadeMs" class="ms-input" /> ms
            </div>

            @* Slider tempa — wyłącznie dla warstwy Text. Porównanie case-insensitive
               (defensywne — backend daje canonical "Text", ale gdyby kiedyś przyszedł
               "text"/"TEXT", chcemy mimo to pokazać kontrolkę). Zakres 0.75–1.25
               z krokiem 0.05 to "sweet spot" przy preservesPitch — szersze ekstrema
               dają cyfrowe artefakty time-stretchu nawet z zachowaniem pitcha. *@
            @if (string.Equals(LayerType, "Text", StringComparison.OrdinalIgnoreCase))
            {
                <div class="detail-row speed-row">
                    <span class="detail-label">Speed</span>
                    <input type="range" min="0.75" max="1.25" step="0.05"
                           value="@_playbackRate.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                           @oninput="e => OnPlaybackRateInput(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                           @onchange="e => OnPlaybackRateChange(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                           class="medytao-slider speed-slider"
                           style="--slider-fill: @SpeedFillPercent()%"
                           title="Playback speed (1.00× = normal)" />
                    <span class="speed-value">@_playbackRate.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)×</span>
                    @if (Math.Abs(_playbackRate - 1.0f) > 0.001f)
                    {
                        <button class="speed-reset" @onclick="ResetPlaybackRate" title="Reset to 1.00×">↺ reset</button>
                    }
                </div>
            }

            @* Slider reverbu — zawsze widoczny dla każdego tracka (Hall jest
               jedynym presetem). Zakres 0..1 z krokiem 0.01 dla precyzji.
               0% = pełne dry (graf bypassuje convolver), 100% = pełen wet. *@
            <div class="detail-row reverb-row">
                <span class="detail-label">Reverb (Hall)</span>
                <input type="range" min="0" max="1" step="0.01"
                       value="@_reverbMix.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                       @oninput="e => OnReverbMixInput(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                       @onchange="e => OnReverbMixChange(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                       class="medytao-slider reverb-slider"
                       style="--slider-fill: @((int)(_reverbMix * 100))%"
                       title="Reverb wet/dry mix (0% = no effect)" />
                <span class="reverb-mix-value">@((int)(_reverbMix * 100))%</span>
            </div>

            @* Time-anchored start: checkbox włącza tryb, mm:ss input ustawia
               moment master-clocka, w którym track ma wystartować. Dla warstwy
               Text/Fx silnik odpala overlay; dla Music/Nature na razie tylko
               persistujemy wartość — info pod inputem mówi "coming soon".
               Toggle off = StartAtMs zostaje wyzerowane (null) → tryb sekwencyjny. *@
            <div class="detail-row start-at-row">
                <label class="start-at-toggle">
                    <input type="checkbox" checked="@_startAtEnabled" @onchange="OnStartAtToggle" />
                    <span class="detail-label start-at-label">Start at specific time</span>
                </label>
                @if (_startAtEnabled)
                {
                    <input type="text" class="mmss-input"
                           value="@FormatMmSs(_startAtMs)"
                           @onchange="e => OnStartAtMmSsChange(e.Value?.ToString())"
                           placeholder="mm:ss" />
                    <span class="start-at-note" title="@StartAtNoteTitle()">@StartAtNoteText()</span>
                }
            </div>

            <div class="detail-actions">
                <button class="btn-save" @onclick="SaveDetail">Save changes</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TrackDto Track { get; set; } = null!;
    [Parameter, EditorRequired] public Guid LayerId { get; set; }
    /// <summary>
    /// Typ warstwy ("Music"/"Nature"/"Text"/"Fx"). Steruje widocznością
    /// kontrolek specyficznych dla danej warstwy — dziś slider tempa
    /// pojawia się wyłącznie dla "Text" (lektor).
    /// </summary>
    [Parameter, EditorRequired] public string LayerType { get; set; } = "";
    /// <summary>
    /// True when this track loops forever AND there are later tracks in the same layer
    /// that will never play because of that. Shown as a subtle ∞ badge.
    /// </summary>
    [Parameter] public bool BlocksSequence { get; set; }
    /// <summary>
    /// True, gdy playback leci i akurat ten track jest aktywny w swojej warstwie.
    /// Rysujemy subtelny akcent żeby było wiadomo "co teraz słyszę".
    /// </summary>
    [Parameter] public bool IsCurrent { get; set; }

    /// <summary>
    /// Czy panel parametrów (expanded detail) ma być widoczny. Stan
    /// trzymany w parencie (LayerPanel) — toggle "tylko jeden expanded
    /// per warstwa" wymaga centralnego sterowania.
    /// </summary>
    [Parameter] public bool IsExpanded { get; set; }

    /// <summary>
    /// Wywoływane gdy user kliknie w track-row (toggle) lub gdy chcemy
    /// programmatically zamknąć panel (np. po Save changes). Parent
    /// decyduje czy panel ma się otworzyć/zamknąć — typowo: ustawia
    /// _expandedTrackId na ten Track.Id (otwórz) albo na null (zamknij).
    /// </summary>
    [Parameter] public EventCallback OnToggleExpand { get; set; }

    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }

    /// <summary>
    /// Wywoływane gdy user rozpoczyna drag chwytając za uchwyt ⠿. Parent
    /// (LayerPanel) używa tego do oznaczenia tego tracka jako source dragu
    /// i przygotowania snapshotu kolejności do live-preview.
    /// </summary>
    [Parameter] public EventCallback OnDragStartFromHandle { get; set; }

    /// <summary>
    /// Wywoływane na zakończenie drag-u (drop poza listą lub anulowanie).
    /// Parent czyści wewnętrzny stan dragu.
    /// </summary>
    [Parameter] public EventCallback OnDragEndFromHandle { get; set; }

    private float _volume;
    private int _loopCount;
    private int _fadeInMs, _fadeOutMs, _startOffsetMs, _crossfadeMs;
    private float _playbackRate;
    private float _reverbMix;
    private bool _startAtEnabled;
    private int _startAtMs;

    // Shadow-y per-pole — kopiujemy Track.X do _x tylko gdy parametr zmienił
    // się z zewnątrz. Bez tego progress-timer sesji playbacku (tick co 250ms)
    // resetowałby suwaki Volume / Speed / Reverb do starej wartości w środku
    // drag-u, bo parent dostaje świeży DTO dopiero po release (persist + refetch).
    // NaN/min-int = sentinel "jeszcze nie widziane" → pierwszy render zawsze inicjalizuje.
    private float _shadowVolume = float.NaN;
    private int _shadowLoopCount = int.MinValue;
    private int _shadowFadeIn = int.MinValue, _shadowFadeOut = int.MinValue;
    private int _shadowStartOffset = int.MinValue, _shadowCrossfade = int.MinValue;
    private float _shadowPlaybackRate = float.NaN;
    private float _shadowReverbMix = float.NaN;
    // Sentinel "jeszcze nie widziane" dla nullable int — używamy magicznej
    // wartości int.MinValue, bo prawdziwy StartAtMs jest >=0. Track.StartAtMs
    // == null mapujemy na _shadowStartAt = -1 i _startAtEnabled = false.
    private int _shadowStartAt = int.MinValue;

    protected override void OnParametersSet()
    {
        if (!FloatEquals(_shadowVolume, Track.Volume))
        {
            _shadowVolume = Track.Volume;
            _volume = Track.Volume;
        }
        if (_shadowLoopCount != Track.LoopCount)
        {
            _shadowLoopCount = Track.LoopCount;
            _loopCount = Track.LoopCount;
        }
        if (_shadowFadeIn != Track.FadeInMs)
        {
            _shadowFadeIn = Track.FadeInMs;
            _fadeInMs = Track.FadeInMs;
        }
        if (_shadowFadeOut != Track.FadeOutMs)
        {
            _shadowFadeOut = Track.FadeOutMs;
            _fadeOutMs = Track.FadeOutMs;
        }
        if (_shadowStartOffset != Track.StartOffsetMs)
        {
            _shadowStartOffset = Track.StartOffsetMs;
            _startOffsetMs = Track.StartOffsetMs;
        }
        if (_shadowCrossfade != Track.CrossfadeMs)
        {
            _shadowCrossfade = Track.CrossfadeMs;
            _crossfadeMs = Track.CrossfadeMs;
        }
        if (!FloatEquals(_shadowPlaybackRate, Track.PlaybackRate))
        {
            _shadowPlaybackRate = Track.PlaybackRate;
            _playbackRate = Track.PlaybackRate;
        }
        if (!FloatEquals(_shadowReverbMix, Track.ReverbMix))
        {
            _shadowReverbMix = Track.ReverbMix;
            _reverbMix = Track.ReverbMix;
        }
        // -1 jako "kanonicznie null" dla shadow comparisons. Track.StartAtMs ?? -1
        // robi to samo dla rzeczywistej wartości, więc porównanie jest spójne.
        var incomingStartAt = Track.StartAtMs ?? -1;
        if (_shadowStartAt != incomingStartAt)
        {
            _shadowStartAt = incomingStartAt;
            _startAtEnabled = Track.StartAtMs.HasValue;
            _startAtMs = Track.StartAtMs ?? 0;
        }
    }

    private static bool FloatEquals(float a, float b) =>
        !float.IsNaN(a) && !float.IsNaN(b) && Math.Abs(a - b) < 0.0001f;

    // Klik w track-row deleguje decyzję parentowi; LayerPanel toggle'uje
    // _expandedTrackId, co wraca tu jako IsExpanded i renderuje panel.
    private Task ToggleExpand() => OnToggleExpand.InvokeAsync();

    private async Task OnVolumeInput(float v)
    {
        // Fires na każdy piksel drag'u. Aktualizujemy lokalny stan (żeby
        // AudioPreviewButton i sesja medytaoPlayer dostały nową wartość na żywo),
        // ale NIE persist'ujemy do bazy — poczekamy na finalny onchange po
        // puszczeniu suwaka.
        _volume = v;
        await PlaybackSession.SetTrackVolumeAsync(LayerId, Track.Id, v);
    }

    private async Task OnVolumeChange(float v)
    {
        _volume = v;
        await PlaybackSession.SetTrackVolumeAsync(LayerId, Track.Id, v);
        await PersistAsync();
        await OnChanged.InvokeAsync();
    }

    private async Task OnLoopCountChange(int n)
    {
        if (n < 0) n = 0;
        if (n > 99) n = 99;
        _loopCount = n;
        await PersistAsync();
        await OnChanged.InvokeAsync();
    }

    private async Task SaveDetail()
    {
        await PersistAsync();
        // Po zapisie zamykamy panel — wywołanie OnToggleExpand z IsExpanded=true
        // przełącza parent state na null, więc kolejny render zamknie panel.
        await OnToggleExpand.InvokeAsync();
        await OnChanged.InvokeAsync();
    }

    // Tempo: drag = live update silnika audio bez DB; release = persist.
    // Dzięki temu user słyszy zmianę natychmiast (preservesPitch działa
    // na żywo na <audio>), a do bazy idzie jedna PUT-ka po puszczeniu.
    private async Task OnPlaybackRateInput(float v)
    {
        _playbackRate = v;
        await PlaybackSession.SetTrackPlaybackRateAsync(LayerId, Track.Id, v);
    }

    private async Task OnPlaybackRateChange(float v)
    {
        _playbackRate = v;
        await PlaybackSession.SetTrackPlaybackRateAsync(LayerId, Track.Id, v);
        await PersistAsync();
        await OnChanged.InvokeAsync();
    }

    private async Task ResetPlaybackRate()
    {
        _playbackRate = 1.0f;
        await PlaybackSession.SetTrackPlaybackRateAsync(LayerId, Track.Id, 1.0f);
        await PersistAsync();
        await OnChanged.InvokeAsync();
    }

    // Wypełnienie suwaka 0–100% w obrębie zakresu 0.75–1.25 (długość 0.5).
    private int SpeedFillPercent()
    {
        const float min = 0.75f, max = 1.25f;
        var clamped = Math.Clamp(_playbackRate, min, max);
        return (int)Math.Round((clamped - min) / (max - min) * 100);
    }

    // Reverb mix — drag = live update silnika audio (zmiana wet/dry gain
    // słyszalna od razu, bez glitchu), release = persist.
    private async Task OnReverbMixInput(float v)
    {
        _reverbMix = v;
        await PlaybackSession.SetTrackReverbMixAsync(LayerId, Track.Id, v);
    }

    private async Task OnReverbMixChange(float v)
    {
        _reverbMix = v;
        await PlaybackSession.SetTrackReverbMixAsync(LayerId, Track.Id, v);
        await PersistAsync();
        await OnChanged.InvokeAsync();
    }

    // Toggle "Start at specific time": włączenie ⇒ używamy aktualnej wartości
    // _startAtMs (lub 0 jeśli pusta), wyłączenie ⇒ wracamy do tryb sekwencyjny
    // (StartAtMs = null w bazie). Po toggle persist od razu, żeby user widział
    // efekt natychmiast (silnik audio na live-update reaguje przy następnym
    // restarcie sesji — Stop+Play; live re-schedulowanie podczas grania
    // zostawiamy jako follow-up, jeśli okaże się potrzebne).
    private async Task OnStartAtToggle(ChangeEventArgs e)
    {
        _startAtEnabled = e.Value is bool b && b;
        await PersistAsync();
        await OnChanged.InvokeAsync();
    }

    private async Task OnStartAtMmSsChange(string? raw)
    {
        var parsed = ParseMmSs(raw);
        if (parsed.HasValue) _startAtMs = parsed.Value;
        await PersistAsync();
        await OnChanged.InvokeAsync();
    }

    // Parsuje "mm:ss" (np. "2:30" → 150000 ms). Akceptuje też samą liczbę
    // sekund ("90" → 90000). Bezpieczne na puste/nieparsowalne — zwraca null,
    // wartość się nie zmienia. Zakres na sekundach 0..59 wymuszamy w trakcie
    // parsowania (60+ sekund powinno być wyrażone w minutach).
    private static int? ParseMmSs(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return null;
        raw = raw.Trim();
        if (raw.Contains(':'))
        {
            var parts = raw.Split(':', 2);
            if (parts.Length != 2) return null;
            if (!int.TryParse(parts[0], out var m) || !int.TryParse(parts[1], out var s)) return null;
            if (m < 0 || s < 0 || s > 59) return null;
            return (m * 60 + s) * 1000;
        }
        if (int.TryParse(raw, out var seconds))
        {
            if (seconds < 0) return null;
            return seconds * 1000;
        }
        return null;
    }

    private static string FormatMmSs(int ms)
    {
        if (ms < 0) ms = 0;
        var total = ms / 1000;
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    // Podpis pod inputem mm:ss różny per warstwa — informuje co realnie
    // robi silnik audio z time-anchored trackiem w tej warstwie.
    private string StartAtNoteText() => LayerType?.ToLowerInvariant() switch
    {
        "text" => "Cuts in, replacing the previous fragment",
        "fx" => "Plays as one-shot accent",
        "music" => "Crossfades over the current track",
        "nature" => "Crossfades over the current track",
        _ => ""
    };

    private string StartAtNoteTitle() => LayerType?.ToLowerInvariant() switch
    {
        "music" => "Crossfade duration uses 'Crossfade to next' (or 'Fade in' as fallback, default 3s)",
        "nature" => "Crossfade duration uses 'Crossfade to next' (or 'Fade in' as fallback, default 3s)",
        _ => ""
    };

    private Task PersistAsync()
    {
        // Przekazujemy _startAtMs tylko gdy toggle jest on; off ⇒ null
        // (tryb sekwencyjny w bazie).
        int? startAt = _startAtEnabled ? Math.Max(0, _startAtMs) : (int?)null;
        return MeditationSvc.UpdateTrackAsync(Track.Id, LayerId, _volume, _loopCount,
            _fadeInMs, _fadeOutMs, _startOffsetMs, _crossfadeMs, _playbackRate, _reverbMix, startAt);
    }

    private async Task Remove()
    {
        await MeditationSvc.RemoveTrackAsync(LayerId, Track.Id);
        await OnRemove.InvokeAsync();
    }

    private static string FormatDuration(int ms) =>
        $"{ms / 60000}:{(ms % 60000 / 1000):D2}";
}

<style>
    .track-card {
        border-bottom: 1px solid var(--color-border-tertiary);
        border-left: 3px solid transparent;
        transition: border-left-color 0.15s, background 0.15s;
    }
    .track-card:last-child { border-bottom: none; }
    .track-card.current { border-left-color: var(--color-text-info); }
    .track-card.current .track-row { background: var(--color-background-secondary); }

    .track-row {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 18px; cursor: pointer;
        transition: background 0.1s;
    }
    .track-row:hover { background: var(--color-background-secondary); }

    .drag-handle {
        color: var(--color-text-tertiary);
        cursor: grab;
        font-size: 14px;
        /* Większy hit-target niż sam glyph ⠿ — łatwiej trafić myszką, plus
           subtelne tło na hover sygnalizuje, że to interaktywny element. */
        padding: 2px 4px;
        border-radius: 4px;
        user-select: none;
        transition: background 0.1s, color 0.1s;
    }
    .drag-handle:hover { background: var(--color-background-secondary); color: var(--color-text-secondary); }
    .drag-handle:active { cursor: grabbing; }

    .track-info { flex: 1; min-width: 0; }
    .track-filename { font-size: 13px; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .track-duration { font-size: 11px; color: var(--color-text-tertiary); }

    .blocks-sequence {
        margin-left: 6px;
        font-size: 11px;
        color: var(--color-text-warning, #c97a00);
        cursor: help;
    }

    .track-quick-controls { display: flex; align-items: center; gap: 8px; }
    .vol-slider { width: 90px; }
    .vol-value { font-size: 11px; color: var(--color-text-secondary); min-width: 32px; text-align: right; }

    .loop-control {
        display: flex; align-items: center; gap: 2px;
        padding: 2px 8px; border-radius: 20px;
        border: 1px solid var(--color-border-secondary);
        background: none; font-size: 12px; color: var(--color-text-secondary);
    }
    .loop-icon { font-size: 12px; }
    .loop-input {
        width: 36px; border: none; background: transparent;
        font-size: 12px; color: var(--color-text-primary); text-align: right;
        -moz-appearance: textfield; appearance: textfield;
    }
    .loop-input::-webkit-outer-spin-button,
    .loop-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .loop-input:focus { outline: none; }
    .loop-infinity { font-size: 14px; color: var(--color-text-info); }
    .loop-x { font-size: 11px; color: var(--color-text-tertiary); }

    .remove-btn {
        background: none; border: none; font-size: 18px; line-height: 1;
        color: var(--color-text-tertiary); cursor: pointer;
        padding: 2px 6px; border-radius: 4px;
    }
    .remove-btn:hover { color: var(--color-text-danger); background: var(--color-background-danger); }

    .expand-arrow { font-size: 11px; color: var(--color-text-tertiary); }

    .track-detail {
        padding: 14px 18px 18px 44px;
        background: var(--color-background-secondary);
        display: flex; flex-wrap: wrap; gap: 12px 24px;
    }
    .detail-row { display: flex; align-items: center; gap: 8px; font-size: 13px; }
    .detail-label { color: var(--color-text-secondary); min-width: 110px; }
    .ms-input {
        width: 72px; padding: 4px 8px; border-radius: 4px;
        border: 1px solid var(--color-border-secondary);
        background: var(--color-background-primary);
        color: var(--color-text-primary); font-size: 13px;
    }
    /* Slider tempa w expanded panelu — wśród Fade in / Fade out / itd.
       Zajmuje pełną szerokość rzędu (gap między detail-row 12px) i daje
       userowi miejsce na precyzyjny drag. */
    .detail-row.speed-row { flex: 1 1 100%; gap: 10px; }
    .speed-slider { flex: 0 0 220px; }
    .speed-value {
        font-size: 13px;
        color: var(--color-text-primary);
        min-width: 56px;
        font-variant-numeric: tabular-nums;
    }
    .speed-reset {
        background: none;
        border: 1px solid var(--color-border-secondary);
