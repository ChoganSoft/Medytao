@using Medytao.Shared.Models
@implements IDisposable
@inject MeditationService MeditationSvc
@inject PlaybackSessionService PlaybackSession

<div class="layer-panel @(Layer.Muted ? "muted" : "")">
    <!-- Layer header -->
    <div class="layer-header">
        <div class="layer-identity">
            <span class="layer-icon">@LayerIcon(Layer.Type)</span>
            <span class="layer-name">@Layer.Type</span>
            <span class="track-count">@Layer.Tracks.Count() track@(Layer.Tracks.Count() != 1 ? "s" : "")</span>
        </div>
        <div class="layer-controls">
            <label class="volume-label">Vol</label>
            <input type="range" min="0" max="1" step="0.01"
                   value="@_localVolume.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                   @oninput="e => DragVolume(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   @onchange="e => UpdateVolume(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   class="medytao-slider volume-slider"
                   style="--slider-fill: @((int)(_localVolume * 100))%" />
            <span class="volume-value">@((int)(_localVolume * 100))%</span>
            <button class="mute-btn @(Layer.Muted ? "active" : "")" @onclick="ToggleMute" title="Mute layer">
                @(Layer.Muted ? "🔇" : "🔊")
            </button>
            @{
                var progress = PlaybackSession.GetProgress(Layer.Id);
                var showProgress = PlaybackSession.IsPlaying && Layer.Tracks.Any();
            }
            <div class="layer-progress @(showProgress ? "active" : "")" title="@(showProgress ? ProgressTooltip(progress) : "")">
                @if (showProgress)
                {
                    <div class="layer-progress-fill" style="@LayerProgressStyle(progress)"></div>
                }
            </div>
        </div>
        <button class="add-track-btn" @onclick="() => OnOpenAssetPicker.InvokeAsync()">+ Add track</button>
    </div>

    <!-- Track list -->
    @if (!Layer.Tracks.Any())
    {
        <div class="empty-layer">
            <span>No tracks yet — add an asset to get started</span>
        </div>
    }
    else
    {
        <div class="track-list">
            @{
                var ordered = Layer.Tracks.OrderBy(t => t.Order).ToList();
                var lastIndex = ordered.Count - 1;
            }
            @for (var i = 0; i < ordered.Count; i++)
            {
                var track = ordered[i];
                var blocks = track.LoopCount == 0 && i < lastIndex;
                <TrackCard
                    Track="track"
                    LayerId="Layer.Id"
                    BlocksSequence="blocks"
                    IsCurrent="@(progress is not null && !progress.Finished && progress.TrackIndex == i)"
                    OnChanged="OnLayerChanged"
                    OnRemove="OnLayerChanged" />
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public LayerDto Layer { get; set; } = null!;
    [Parameter] public EventCallback OnLayerChanged { get; set; }
    [Parameter] public EventCallback OnOpenAssetPicker { get; set; }

    // Lokalny cache — aktualizowany na każdy oninput (live), żeby suwak
    // nie skakał do poprzedniej wartości podczas drag'u (parent refetchuje
    // DTO dopiero po zwolnieniu przycisku).
    private float _localVolume;

    protected override void OnInitialized()
    {
        PlaybackSession.OnChanged += HandleSessionChanged;
    }

    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    protected override void OnParametersSet()
    {
        _localVolume = Layer.Volume;
    }

    private async Task DragVolume(float volume)
    {
        _localVolume = volume;
        await PlaybackSession.SetLayerVolumeAsync(Layer.Id, volume);
    }

    private async Task UpdateVolume(float volume)
    {
        _localVolume = volume;
        // Live-update najpierw, żeby user usłyszał różnicę natychmiast —
        // persist do bazy i odświeżenie DTO mogą trochę zająć.
        await PlaybackSession.SetLayerVolumeAsync(Layer.Id, volume);
        await MeditationSvc.UpdateLayerAsync(Layer.Id, volume, Layer.Muted);
        await OnLayerChanged.InvokeAsync();
    }

    private async Task ToggleMute()
    {
        var newMuted = !Layer.Muted;
        await PlaybackSession.SetLayerMutedAsync(Layer.Id, newMuted);
        await MeditationSvc.UpdateLayerAsync(Layer.Id, Layer.Volume, newMuted);
        await OnLayerChanged.InvokeAsync();
    }

    private static string LayerProgressStyle(PlaybackSessionService.LayerProgress? p)
    {
        var pct = (p is not null && p.Duration > 0)
            ? Math.Clamp(p.CurrentTime / p.Duration * 100.0, 0, 100)
            : 0;
        return string.Create(System.Globalization.CultureInfo.InvariantCulture, $"width: {pct:0.##}%");
    }

    private static string ProgressTooltip(PlaybackSessionService.LayerProgress? p)
    {
        if (p is null) return "";
        if (p.Finished) return "Finished";
        return $"Track {p.TrackIndex + 1}/{p.TrackCount} · {FormatTime(p.CurrentTime)} / {FormatTime(p.Duration)}";
    }

    private static string FormatTime(double seconds)
    {
        if (!double.IsFinite(seconds) || seconds < 0) seconds = 0;
        var total = (int)Math.Floor(seconds);
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    public void Dispose()
    {
        PlaybackSession.OnChanged -= HandleSessionChanged;
    }

    private static string LayerIcon(string type) => type switch
    {
        "Music"  => "♪",
        "Text"   => "≡",
        "Nature" => "〜",
        "Fx"     => "✦",
        _        => "○"
    };
}

<style>
    .layer-panel {
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 10px; overflow: hidden;
        transition: opacity 0.2s;
    }
    .layer-panel.muted { opacity: 0.55; }

    .layer-header {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 18px;
        border-bottom: 1px solid var(--color-border-tertiary);
        background: var(--color-background-secondary);
    }

    .layer-identity { display: flex; align-items: center; gap: 8px; min-width: 160px; }
    .layer-icon { font-size: 16px; }
    .layer-name { font-size: 14px; font-weight: 500; }
    .track-count { font-size: 12px; color: var(--color-text-tertiary); }

    .layer-controls { display: flex; align-items: center; gap: 8px; flex: 1; }
    .volume-label { font-size: 12px; color: var(--color-text-secondary); }
    .volume-slider { flex: 0 0 auto; width: 160px; }
    .volume-value { font-size: 12px; color: var(--color-text-secondary); min-width: 32px; }

    /* Pasek postępu rezerwuje miejsce nawet gdy nic nie gra, żeby layout
       nie skakał przy toggle play/stop. Widoczny wypełnieniem dopiero gdy .active. */
    .layer-progress {
        flex: 1;
        min-width: 80px;
        max-width: 280px;
        height: 4px;
        background: transparent;
        border-radius: 2px;
        overflow: hidden;
        margin-left: 4px;
        transition: background 0.2s;
    }
    .layer-progress.active {
        background: var(--color-border-tertiary);
    }
    .layer-progress-fill {
        height: 100%;
        background: var(--color-text-info);
        transition: width 0.2s linear;
    }

    .mute-btn {
        background: none; border: 1px solid var(--color-border-tertiary);
        border-radius: 6px; padding: 4px 8px; cursor: pointer;
        font-size: 14px; line-height: 1;
        transition: background 0.1s;
    }
    .mute-btn.active { background: var(--color-background-warning); border-color: var(--color-border-warning); }

    .add-track-btn {
        margin-left: auto;
        padding: 6px 14px; border-radius: 6px;
        background: var(--color-background-tertiary);
        border: 1px solid var(--color-border-secondary);
        font-size: 13px; color: var(--color-text-secondary);
        cursor: pointer;
    }
    .add-track-btn:hover { color: var(--color-text-primary); border-color: var(--color-border-primary); }

    .empty-layer {
        padding: 24px 18px; text-align: center;
        color: var(--color-text-tertiary); font-size: 13px;
    }

    .track-list { display: flex; flex-direction: column; }
</style>
