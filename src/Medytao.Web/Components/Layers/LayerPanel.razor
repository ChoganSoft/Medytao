@using Medytao.Shared.Models
@implements IDisposable
@inject MeditationService MeditationSvc
@inject PlaybackSessionService PlaybackSession

<div class="layer-panel @(Layer.Muted ? "muted" : "")">
    <!-- Layer header -->
    <div class="layer-header">
        <div class="layer-identity">
            <i class="@LayerIcon(Layer.Type) layer-icon" aria-hidden="true"></i>
            <span class="layer-name">@Layer.Type</span>
            <span class="track-count">@Layer.Tracks.Count() track@(Layer.Tracks.Count() != 1 ? "s" : "")</span>
        </div>
        <div class="layer-controls">
            <label class="volume-label">Vol</label>
            <input type="range" min="0" max="1" step="0.01"
                   value="@_localVolume.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                   @oninput="e => DragVolume(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   @onchange="e => UpdateVolume(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   class="medytao-slider volume-slider"
                   style="--slider-fill: @((int)(_localVolume * 100))%" />
            <span class="volume-value">@((int)(_localVolume * 100))%</span>
            <button class="mute-btn @(Layer.Muted ? "active" : "")" @onclick="ToggleMute" title="Mute layer">
                @(Layer.Muted ? "🔇" : "🔊")
            </button>
            @{
                var progress = PlaybackSession.GetProgress(Layer.Id);
                var showProgress = PlaybackSession.IsPlaying && Layer.Tracks.Any();
                const double ringRadius = 13d;
                var ringCirc = 2 * Math.PI * ringRadius;
                var ringOffset = ringCirc * (1 - ProgressFraction(progress));
            }
            <span class="layer-ring-wrap" title="@(showProgress ? ProgressTooltip(progress) : "")">
                <svg class="layer-ring @(showProgress ? "active" : "")"
                     width="32" height="32" viewBox="0 0 32 32"
                     aria-hidden="true">
                    <circle class="ring-bg" cx="16" cy="16" r="@(ringRadius.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    @if (showProgress)
                    {
                        <circle class="ring-fill" cx="16" cy="16" r="@(ringRadius.ToString(System.Globalization.CultureInfo.InvariantCulture))"
                                stroke-dasharray="@(ringCirc.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))"
                                stroke-dashoffset="@(ringOffset.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))" />
                    }
                </svg>
            </span>
        </div>
        <button class="add-track-btn" @onclick="() => OnOpenAssetPicker.InvokeAsync()">+ Add track</button>
    </div>

    @* Pasek reverbu — zawsze widoczny pod headerem warstwy. Trzy pill-buttony
       presetu + slider wet/dry mixu (renderowany tylko gdy preset != Off,
       żeby pasek nie był wizualnie głośny gdy efekt nieaktywny). *@
    <div class="layer-reverb-bar">
        <span class="reverb-label" title="Layer-wide reverb effect">Reverb</span>
        <div class="reverb-presets" role="group" aria-label="Reverb preset">
            @foreach (var preset in ReverbPresetOptions)
            {
                var active = string.Equals(_localPreset, preset, StringComparison.OrdinalIgnoreCase);
                <button class="reverb-preset @(active ? "active" : "")"
                        @onclick="() => SelectPreset(preset)"
                        type="button">@preset</button>
            }
        </div>
        @if (!string.Equals(_localPreset, "Off", StringComparison.OrdinalIgnoreCase))
        {
            <input type="range" min="0" max="1" step="0.01"
                   value="@_localMix.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                   @oninput="e => DragMix(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   @onchange="e => UpdateMix(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   class="medytao-slider reverb-slider"
                   style="--slider-fill: @((int)(_localMix * 100))%"
                   title="Reverb wet/dry mix" />
            <span class="reverb-mix-value">@((int)(_localMix * 100))%</span>
        }
    </div>

    <!-- Track list -->
    @if (!Layer.Tracks.Any())
    {
        <div class="empty-layer">
            <span>No tracks yet — add an asset to get started</span>
        </div>
    }
    else
    {
        <div class="track-list">
            @{
                var ordered = Layer.Tracks.OrderBy(t => t.Order).ToList();
                var lastIndex = ordered.Count - 1;
            }
            @for (var i = 0; i < ordered.Count; i++)
            {
                var track = ordered[i];
                var blocks = track.LoopCount == 0 && i < lastIndex;
                <TrackCard
                    Track="track"
                    LayerId="Layer.Id"
                    LayerType="@Layer.Type"
                    BlocksSequence="blocks"
                    IsCurrent="@(progress is not null && !progress.Finished && progress.TrackIndex == i)"
                    OnChanged="OnLayerChanged"
                    OnRemove="OnLayerChanged" />
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public LayerDto Layer { get; set; } = null!;
    [Parameter] public EventCallback OnLayerChanged { get; set; }
    [Parameter] public EventCallback OnOpenAssetPicker { get; set; }

    // Lokalny cache — aktualizowany na każdy oninput (live), żeby suwak
    // nie skakał do poprzedniej wartości podczas drag'u (parent refetchuje
    // DTO dopiero po zwolnieniu przycisku).
    private float _localVolume;
    private string _localPreset = "Off";
    private float _localMix;

    // Lista presetów do wyrenderowania pill-buttonów. Kolejność świadoma:
    // Off → Room → Hall = od minimum do maximum efektu, użytkownik intuicyjnie
    // klikając w prawo "dodaje" reverbu. Strings = wartości wysyłane do API.
    private static readonly string[] ReverbPresetOptions = ["Off", "Room", "Hall"];

    protected override void OnInitialized()
    {
        PlaybackSession.OnChanged += HandleSessionChanged;
    }

    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    protected override void OnParametersSet()
    {
        _localVolume = Layer.Volume;
        _localPreset = string.IsNullOrWhiteSpace(Layer.ReverbPreset) ? "Off" : Layer.ReverbPreset;
        _localMix = Layer.ReverbMix;
    }

    private async Task DragVolume(float volume)
    {
        _localVolume = volume;
        await PlaybackSession.SetLayerVolumeAsync(Layer.Id, volume);
    }

    private async Task UpdateVolume(float volume)
    {
        _localVolume = volume;
        // Live-update najpierw, żeby user usłyszał różnicę natychmiast —
        // persist do bazy i odświeżenie DTO mogą trochę zająć.
        await PlaybackSession.SetLayerVolumeAsync(Layer.Id, volume);
        await MeditationSvc.UpdateLayerAsync(Layer.Id, volume, Layer.Muted, _localPreset, _localMix);
        await OnLayerChanged.InvokeAsync();
    }

    private async Task ToggleMute()
    {
        var newMuted = !Layer.Muted;
        await PlaybackSession.SetLayerMutedAsync(Layer.Id, newMuted);
        await MeditationSvc.UpdateLayerAsync(Layer.Id, Layer.Volume, newMuted, _localPreset, _localMix);
        await OnLayerChanged.InvokeAsync();
    }

    // Klik w pill presetu. Off ⇒ całkowite wyłączenie; pozostałe ⇒ aktywacja
    // z aktualnym mixem (jeśli mix był 0, wskakujemy w 0.3 — czytelny default,
    // żeby user wybierając "Hall" usłyszał efekt bez dodatkowego klikania w slider).
    private async Task SelectPreset(string preset)
    {
        if (string.Equals(_localPreset, preset, StringComparison.OrdinalIgnoreCase)) return;
        _localPreset = preset;
        var isOff = string.Equals(preset, "Off", StringComparison.OrdinalIgnoreCase);
        if (!isOff && _localMix <= 0f) _localMix = 0.3f;
        if (isOff)
        {
            // Mix zachowujemy w stanie lokalnym? Nie — gdy user wraca do
            // Room/Hall, woli wystartować z czytelnym defaultem (0.3) niż
            // z poprzednim ustawieniem, którego nie pamięta. Reset do 0
            // upraszcza model: "Off = wszystko wyłączone".
            _localMix = 0f;
        }
        await PlaybackSession.SetLayerReverbAsync(Layer.Id, _localPreset, _localMix);
        await MeditationSvc.UpdateLayerAsync(Layer.Id, Layer.Volume, Layer.Muted, _localPreset, _localMix);
        await OnLayerChanged.InvokeAsync();
    }

    private async Task DragMix(float mix)
    {
        _localMix = mix;
        await PlaybackSession.SetLayerReverbAsync(Layer.Id, _localPreset, mix);
    }

    private async Task UpdateMix(float mix)
    {
        _localMix = mix;
        await PlaybackSession.SetLayerReverbAsync(Layer.Id, _localPreset, mix);
        await MeditationSvc.UpdateLayerAsync(Layer.Id, Layer.Volume, Layer.Muted, _localPreset, mix);
        await OnLayerChanged.InvokeAsync();
    }

    // 0.0 .. 1.0 — ile tracka już minęło. Zwraca 0 gdy nie mamy danych.
    private static double ProgressFraction(PlaybackSessionService.LayerProgress? p)
    {
        if (p is null || p.Duration <= 0) return 0;
        return Math.Clamp(p.CurrentTime / p.Duration, 0, 1);
    }

    private static string ProgressTooltip(PlaybackSessionService.LayerProgress? p)
    {
        if (p is null) return "";
        if (p.Finished) return "Finished";
        return $"Track {p.TrackIndex + 1}/{p.TrackCount} · {FormatTime(p.CurrentTime)} / {FormatTime(p.Duration)}";
    }

    private static string FormatTime(double seconds)
    {
        if (!double.IsFinite(seconds) || seconds < 0) seconds = 0;
        var total = (int)Math.Floor(seconds);
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    public void Dispose()
    {
        PlaybackSession.OnChanged -= HandleSessionChanged;
    }

    // Ikony Font Awesome — dokładnie te same, co na złotym pasku karty
    // medytacji (patrz Pages/Index.razor → LayerCategories). CDN Font Awesome
    // dociągany jest w wwwroot/index.html, więc klasy są dostępne globalnie.
    private static string LayerIcon(string type) => type switch
    {
        "Music"  => "fa-solid fa-music",
        "Text"   => "fa-solid fa-comment",
        "Nature" => "fa-solid fa-wind",
        "Fx"     => "fa-solid fa-drum",
        _        => "fa-solid fa-circle"
    };
}

<style>
    .layer-panel {
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 10px; overflow: hidden;
        transition: opacity 0.2s;
    }
    .layer-panel.muted { opacity: 0.55; }

    .layer-header {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 18px;
        border-bottom: 1px solid var(--color-border-tertiary);
        background: var(--color-background-secondary);
    }

    .layer-identity { display: flex; align-items: center; gap: 8px; min-width: 160px; }
    .layer-icon { font-size: 16px; }
    .layer-name { font-size: 14px; font-weight: 500; }
    .track-count { font-size: 12px; color: var(--color-text-tertiary); }

    .layer-controls { display: flex; align-items: center; gap: 8px; flex: 1; }
    .volume-label { font-size: 12px; color: var(--color-text-secondary); }
    .volume-slider { flex: 0 0 auto; width: 160px; }
    .volume-value { font-size: 12px; color: var(--color-text-secondary); min-width: 32px; }

    /* Okrągły wskaźnik postępu. Tło-ring rysujemy zawsze (subtelne),
       ring z wypełnieniem pojawia się tylko gdy sesja leci. Rotate(-90deg)
       żeby start był u góry, a nie po prawej (domyślny kąt 0 to "3 o'clock"). */
    .layer-ring-wrap {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px; height: 32px;
        margin-left: 4px;
    }
    .layer-ring {
        transform: rotate(-90deg);
    }
    .layer-ring .ring-bg {
        fill: none;
        stroke: var(--color-border-tertiary);
        stroke-width: 2.5;
        opacity: 0.5;
    }
    .layer-ring.active .ring-bg {
        opacity: 1;
    }
    .layer-ring .ring-fill {
        fill: none;
        stroke: var(--color-text-info);
        stroke-width: 2.5;
        stroke-linecap: round;
        transition: stroke-dashoffset 0.2s linear;
    }

    .mute-btn {
        background: none; border: 1px solid var(--color-border-tertiary);
        border-radius: 6px; padding: 4px 8px; cursor: pointer;
        font-size: 14px; line-height: 1;
        transition: background 0.1s;
    }
    .mute-btn.active { background: var(--color-background-warning); border-color: var(--color-border-warning); }

    .add-track-btn {
        margin-left: auto;
        padding: 6px 14px; border-radius: 6px;
        background: var(--color-background-tertiary);
        border: 1px solid var(--color-border-secondary);
        font-size: 13px; color: var(--color-text-secondary);
        cursor: pointer;
    }
    .add-track-btn:hover { color: var(--color-text-primary); border-color: var(--color-border-primary); }

    .empty-layer {
        padding: 24px 18px; text-align: center;
        color: var(--color-text-tertiary); font-size: 13px;
    }

    /* Pasek reverbu — nieco subtelniejsze tło niż header, mniejszy padding,
       żeby nie konkurował wagą wizualną z volume. Pill-buttony na podobieństwo
       segmentów; aktywny ma akcent info-color, jak inne aktywne stany w UI. */
    .layer-reverb-bar {
        display: flex; align-items: center; gap: 10px;
        padding: 8px 18px;
        border-bottom: 1px solid var(--color-border-tertiary);
        background: var(--color-background-primary);
        font-size: 12px;
    }
    .reverb-label {
        color: var(--color-text-tertiary);
        min-width: 56px;
        text-transform: uppercase;
        letter-spacing: .04em;
        font-size: 11px;
    }
    .reverb-presets {
        display: inline-flex;
        border: 1px solid var(--color-border-secondary);
        border-radius: 6px;
        overflow: hidden;
    }
    .reverb-preset {
        background: transparent;
        border: none;
        padding: 4px 12px;
        font-size: 12px;
        color: var(--color-text-secondary);
        cursor: pointer;
        border-right: 1px solid var(--color-border-tertiary);
        transition: background .1s, color .1s;
    }
    .reverb-preset:last-child { border-right: none; }
    .reverb-preset:hover { background: var(--color-background-secondary); color: var(--color-text-primary); }
    .reverb-preset.active {
        background: var(--color-background-info);
        color: var(--color-text-info);
        font-weight: 500;
    }

    .reverb-slider { width: 140px; }
    .reverb-mix-value {
        font-size: 11px;
        color: var(--color-text-secondary);
        min-width: 32px;
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .track-list { display: flex; flex-direction: column; }
</style>
