@using Medytao.Shared.Models
@implements IDisposable
@inject MeditationService MeditationSvc
@inject PlaybackSessionService PlaybackSession

<div class="layer-panel @(Layer.Muted ? "muted" : "")">
    <!-- Layer header -->
    <div class="layer-header">
        <div class="layer-identity">
            <i class="@LayerIcon(Layer.Type) layer-icon" aria-hidden="true"></i>
            <span class="layer-name">@Layer.Type</span>
            <span class="track-count">@Layer.Tracks.Count() track@(Layer.Tracks.Count() != 1 ? "s" : "")</span>
        </div>
        <div class="layer-controls">
            <label class="volume-label">Vol</label>
            <input type="range" min="0" max="1" step="0.01"
                   value="@_localVolume.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                   @oninput="e => DragVolume(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   @onchange="e => UpdateVolume(float.Parse(e.Value!.ToString()!, System.Globalization.CultureInfo.InvariantCulture))"
                   class="medytao-slider volume-slider"
                   style="--slider-fill: @((int)(_localVolume * 100))%" />
            <span class="volume-value">@((int)(_localVolume * 100))%</span>
            <button class="mute-btn @(Layer.Muted ? "active" : "")" @onclick="ToggleMute" title="Mute layer">
                @(Layer.Muted ? "🔇" : "🔊")
            </button>
            @{
                var progress = PlaybackSession.GetProgress(Layer.Id);
                var showProgress = PlaybackSession.IsPlaying && Layer.Tracks.Any();
                const double ringRadius = 13d;
                var ringCirc = 2 * Math.PI * ringRadius;
                var ringOffset = ringCirc * (1 - ProgressFraction(progress));
            }
            <span class="layer-ring-wrap" title="@(showProgress ? ProgressTooltip(progress) : "")">
                <svg class="layer-ring @(showProgress ? "active" : "")"
                     width="32" height="32" viewBox="0 0 32 32"
                     aria-hidden="true">
                    <circle class="ring-bg" cx="16" cy="16" r="@(ringRadius.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    @if (showProgress)
                    {
                        <circle class="ring-fill" cx="16" cy="16" r="@(ringRadius.ToString(System.Globalization.CultureInfo.InvariantCulture))"
                                stroke-dasharray="@(ringCirc.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))"
                                stroke-dashoffset="@(ringOffset.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))" />
                    }
                </svg>
            </span>
        </div>
        <button class="add-track-btn" @onclick="() => OnOpenAssetPicker.InvokeAsync()">+ Add track</button>
    </div>

    <!-- Track list -->
    @if (!Layer.Tracks.Any())
    {
        <div class="empty-layer">
            <span>No tracks yet — add an asset to get started</span>
        </div>
    }
    else
    {
        <div class="track-list" @ondragover:preventDefault="true">
            @{
                @* Lokalna lista — gdy trwa drag, używamy `_orderedDuringDrag`
                   (lokalna kopia, zmodyfikowana w OnDragOver dla live-preview
                   nowej kolejności). Bez drag-u → bierzemy ze świeżego DTO. *@
                var ordered = (_orderedDuringDrag is not null && _draggingId is not null)
                    ? _orderedDuringDrag
                    : Layer.Tracks.OrderBy(t => t.Order).ToList();
                var lastIndex = ordered.Count - 1;
            }
            @for (var i = 0; i < ordered.Count; i++)
            {
                var track = ordered[i];
                var blocks = track.LoopCount == 0 && i < lastIndex;
                var trackIdLocal = track.Id; // closure capture per iterację
                <div class="track-drag-wrap @(_draggingId == trackIdLocal ? "dragging" : "")"
                     @key="trackIdLocal"
                     draggable="true"
                     @ondragstart="@(() => OnDragStart(trackIdLocal))"
                     @ondragend="OnDragEnd"
                     @ondragover:preventDefault="true"
                     @ondragover="@(e => OnDragOver(e, trackIdLocal))"
                     @ondrop="OnDrop"
                     @ondrop:preventDefault="true">
                    <TrackCard
                        Track="track"
                        LayerId="Layer.Id"
                        LayerType="@Layer.Type"
                        BlocksSequence="blocks"
                        IsCurrent="@(progress is not null && !progress.Finished && progress.TrackIndex == i)"
                        OnChanged="OnLayerChanged"
                        OnRemove="OnLayerChanged" />
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public LayerDto Layer { get; set; } = null!;
    [Parameter] public EventCallback OnLayerChanged { get; set; }
    [Parameter] public EventCallback OnOpenAssetPicker { get; set; }

    // Lokalny cache — aktualizowany na każdy oninput (live), żeby suwak
    // nie skakał do poprzedniej wartości podczas drag'u (parent refetchuje
    // DTO dopiero po zwolnieniu przycisku).
    private float _localVolume;

    // Shadow trzyma ostatnio widzianą wartość parametru z parenta. Bez niej
    // OnParametersSet (wywoływane przy każdym tickcie progress-timera sesji
    // playbacku) nadpisywałby _localVolume aktualnym Layer.Volume — w środku
    // drag-u resetowałoby suwak do starej wartości. NaN = "jeszcze nie
    // widziane", pierwszy render zawsze inicjalizuje.
    private float _shadowVolume = float.NaN;

    // Stan drag-and-drop reorderingu tracków. _draggingId = id tracka, który
    // user przeciąga. _orderedDuringDrag = lokalna kopia listy tracków
    // z aktualnym podglądem nowej kolejności (mutowana w OnDragOver), żeby
    // user widział "live preview" upuszczenia jeszcze przed puszczeniem.
    // Po dropie wartości lecą do backendu przez ReorderTracksAsync; po
    // OnLayerChanged DTO przychodzi z bazy z prawdziwą kolejnością i czyścimy
    // _orderedDuringDrag, żeby wrócić do "źródła prawdy" z parenta.
    private Guid? _draggingId;
    private List<Medytao.Shared.Models.TrackDto>? _orderedDuringDrag;

    protected override void OnInitialized()
    {
        PlaybackSession.OnChanged += HandleSessionChanged;
    }

    private void HandleSessionChanged() => InvokeAsync(StateHasChanged);

    protected override void OnParametersSet()
    {
        // Aktualizuj lokalny stan TYLKO gdy zmienił się parametr od poprzedniego
        // OnParametersSet — inaczej tickujący progress-timer w czasie drag-u
        // resetowałby suwak. NaN-comparison: `NaN != X` jest zawsze true,
        // więc pierwszy render zawsze załapie wartości z DTO.
        if (!FloatEquals(_shadowVolume, Layer.Volume))
        {
            _shadowVolume = Layer.Volume;
            _localVolume = Layer.Volume;
        }
    }

    // Porównanie z tolerancją + traktowanie NaN jako "różne" (NaN != cokolwiek
    // w IEEE 754, więc pierwszy raz przepuszczamy initialize).
    private static bool FloatEquals(float a, float b) =>
        !float.IsNaN(a) && !float.IsNaN(b) && Math.Abs(a - b) < 0.0001f;

    private async Task DragVolume(float volume)
    {
        _localVolume = volume;
        await PlaybackSession.SetLayerVolumeAsync(Layer.Id, volume);
    }

    private async Task UpdateVolume(float volume)
    {
        _localVolume = volume;
        // Live-update najpierw, żeby user usłyszał różnicę natychmiast —
        // persist do bazy i odświeżenie DTO mogą trochę zająć.
        await PlaybackSession.SetLayerVolumeAsync(Layer.Id, volume);
        await MeditationSvc.UpdateLayerAsync(Layer.Id, volume, Layer.Muted);
        await OnLayerChanged.InvokeAsync();
    }

    private async Task ToggleMute()
    {
        var newMuted = !Layer.Muted;
        await PlaybackSession.SetLayerMutedAsync(Layer.Id, newMuted);
        await MeditationSvc.UpdateLayerAsync(Layer.Id, Layer.Volume, newMuted);
        await OnLayerChanged.InvokeAsync();
    }

    // 0.0 .. 1.0 — ile tracka już minęło. Zwraca 0 gdy nie mamy danych.
    private static double ProgressFraction(PlaybackSessionService.LayerProgress? p)
    {
        if (p is null || p.Duration <= 0) return 0;
        return Math.Clamp(p.CurrentTime / p.Duration, 0, 1);
    }

    private static string ProgressTooltip(PlaybackSessionService.LayerProgress? p)
    {
        if (p is null) return "";
        if (p.Finished) return "Finished";
        return $"Track {p.TrackIndex + 1}/{p.TrackCount} · {FormatTime(p.CurrentTime)} / {FormatTime(p.Duration)}";
    }

    private static string FormatTime(double seconds)
    {
        if (!double.IsFinite(seconds) || seconds < 0) seconds = 0;
        var total = (int)Math.Floor(seconds);
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    public void Dispose()
    {
        PlaybackSession.OnChanged -= HandleSessionChanged;
    }

    // ── Drag & drop reordering ────────────────────────────────────────────────
    // Start drag: zapamiętujemy id, robimy snapshot aktualnej kolejności jako
    // bazę dla live-preview. Bez snapshotu OnDragOver musiałby ciągle czytać
    // ze świeżego DTO, gubiąc tymczasową kolejność między tickami.
    private void OnDragStart(Guid trackId)
    {
        _draggingId = trackId;
        _orderedDuringDrag = Layer.Tracks.OrderBy(t => t.Order).ToList();
    }

    // OnDragOver: kursor jest nad jakimś track-wrapem. Mutujemy
    // _orderedDuringDrag — re-render pokaże nową kolejność na żywo. Atrybut
    // ondragover:preventDefault na elemencie jest niezbędny, żeby przeglądarka
    // pozwoliła w ogóle na drop.
    //
    // Logika reorderingu jest zaskakująco prosta: po wyjęciu elementu na
    // pozycji fromIdx i wstawieniu go na toIdx (oryginalnym indeksie hovered),
    // List.Insert daje właściwy efekt w obu kierunkach drag-u — ZA hovered
    // przy ruchu w dół, PRZED hovered przy ruchu w górę. Wynika to z tego, że
    // przy drag-w-dół RemoveAt przesuwa hovered o 1 w lewo, więc Insert(toIdx)
    // ląduje za nim; przy drag-w-górę indeksy >toIdx się nie ruszają.
    private void OnDragOver(Microsoft.AspNetCore.Components.Web.DragEventArgs e, Guid hoverId)
    {
        if (_draggingId is null || _orderedDuringDrag is null) return;
        if (_draggingId == hoverId) return; // hover nad samym source — nic do roboty

        var list = _orderedDuringDrag;
        var fromIdx = list.FindIndex(t => t.Id == _draggingId);
        var toIdx = list.FindIndex(t => t.Id == hoverId);
        if (fromIdx < 0 || toIdx < 0) return;

        var item = list[fromIdx];
        list.RemoveAt(fromIdx);
        list.Insert(toIdx, item);
    }

    // Drop: zatwierdzamy aktualne _orderedDuringDrag jako nową kolejność —
    // wysyłamy do backendu listę GUID-ów, refreshujemy DTO. Stan czyścimy
    // dopiero po OnLayerChanged żeby uniknąć "skoku" wizualnego między
    // wysłaniem a refetchem.
    private async Task OnDrop()
    {
        if (_draggingId is null || _orderedDuringDrag is null)
        {
            ResetDragState();
            return;
        }
        var orderedIds = _orderedDuringDrag.Select(t => t.Id).ToList();
        ResetDragState();
        await MeditationSvc.ReorderTracksAsync(Layer.Id, orderedIds);
        await OnLayerChanged.InvokeAsync();
    }

    // DragEnd: user puścił przycisk myszy poza listą (np. nad sidebarem) lub
    // anulował dragiem ESC. Tylko czyścimy stan, nic nie persystujemy.
    private void OnDragEnd() => ResetDragState();

    private void ResetDragState()
    {
        _draggingId = null;
        _orderedDuringDrag = null;
    }

    // Ikony Font Awesome — dokładnie te same, co na złotym pasku karty
    // medytacji (patrz Pages/Index.razor → LayerCategories). CDN Font Awesome
    // dociągany jest w wwwroot/index.html, więc klasy są dostępne globalnie.
    private static string LayerIcon(string type) => type switch
    {
        "Music"  => "fa-solid fa-music",
        "Text"   => "fa-solid fa-comment",
        "Nature" => "fa-solid fa-wind",
        "Fx"     => "fa-solid fa-drum",
        _        => "fa-solid fa-circle"
    };
}

<style>
    .layer-panel {
        background: var(--color-background-primary);
        border: 1px solid var(--color-border-tertiary);
        border-radius: 10px; overflow: hidden;
        transition: opacity 0.2s;
    }
    .layer-panel.muted { opacity: 0.55; }

    .layer-header {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 18px;
        border-bottom: 1px solid var(--color-border-tertiary);
        background: var(--color-background-secondary);
    }

    .layer-identity { display: flex; align-items: center; gap: 8px; min-width: 160px; }
    .layer-icon { font-size: 16px; }
    .layer-name { font-size: 14px; font-weight: 500; }
    .track-count { font-size: 12px; color: var(--color-text-tertiary); }

    .layer-controls { display: flex; align-items: center; gap: 8px; flex: 1; }
    .volume-label { font-size: 12px; color: var(--color-text-secondary); }
    .volume-slider { flex: 0 0 auto; width: 160px; }
    .volume-value { font-size: 12px; color: var(--color-text-secondary); min-width: 32px; }

    /* Okrągły wskaźnik postępu. Tło-ring rysujemy zawsze (subtelne),
       ring z wypełnieniem pojawia się tylko gdy sesja leci. Rotate(-90deg)
       żeby start był u góry, a nie po prawej (domyślny kąt 0 to "3 o'clock"). */
    .layer-ring-wrap {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px; height: 32px;
        margin-left: 4px;
    }
    .layer-ring {
        transform: rotate(-90deg);
    }
    .layer-ring .ring-bg {
        fill: none;
        stroke: var(--color-border-tertiary);
        stroke-width: 2.5;
        opacity: 0.5;
    }
    .layer-ring.active .ring-bg {
        opacity: 1;
    }
    .layer-ring .ring-fill {
        fill: none;
        stroke: var(--color-text-info);
        stroke-width: 2.5;
        stroke-linecap: round;
        transition: stroke-dashoffset 0.2s linear;
    }

    .mute-btn {
        background: none; border: 1px solid var(--color-border-tertiary);
        border-radius: 6px; padding: 4px 8px; cursor: pointer;
        font-size: 14px; line-height: 1;
        transition: background 0.1s;
    }
    .mute-btn.active { background: var(--color-background-warning); border-color: var(--color-border-warning); }

    .add-track-btn {
        margin-left: auto;
        padding: 6px 14px; border-radius: 6px;
        background: var(--color-background-tertiary);
        border: 1px solid var(--color-border-secondary);
        font-size: 13px; color: var(--color-text-secondary);
        cursor: pointer;
    }
    .add-track-btn:hover { color: var(--color-text-primary); border-color: var(--color-border-primary); }

    .empty-layer {
        padding: 24px 18px; text-align: center;
        color: var(--color-text-tertiary); font-size: 13px;
    }

    .track-list { display: flex; flex-direction: column; }

    /* Wrapper drag-and-drop wokół każdego TrackCard. Element jest draggable
       w całości (nie tylko za uchwyt ⠿) — drag-handle w TrackCard pełni rolę
       wizualnego wskaźnika "tu można chwytać", ale technicznie cały wiersz
       odpowiada na drag. To prostsze niż dynamiczne togglowanie atrybutu
       draggable na mousedown handle, a w praktyce nikomu nie przeszkadza,
       bo inputy w expanded panelu i tak mają stopPropagation na klikach. */
    .track-drag-wrap {
        transition: opacity 0.15s;
    }
    /* Element przeciągany — przygaszony, żeby user widział "to jest źródło".
       Reszta listy zostaje nietknięta wizualnie poza tym, że pozycje
       się zmieniają (live preview reorderingu). */
    .track-drag-wrap.dragging {
        opacity: 0.4;
    }
</style>
