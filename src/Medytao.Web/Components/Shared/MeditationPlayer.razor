@* Pełny player medytacji — miksuje wszystkie 4 warstwy jednocześnie.
   W każdej warstwie tracki grają sekwencyjnie (wg Order).
   Track z LoopCount=0 zapętla się w nieskończoność i blokuje kolejne w warstwie.
   Logika sekwencji siedzi w window.medytaoPlayer (audioPreview.js). *@

@implements IAsyncDisposable

@if (Open)
{
    <div class="player-backdrop">
        <div class="player-modal">
            <div class="player-header">
                <h2>Preview · @Meditation.Title</h2>
                <button class="close-btn" @onclick="HandleClose">×</button>
            </div>

            <!-- Transport -->
            <div class="transport">
                <button class="play-btn" @onclick="TogglePlay">
                    @(_playing ? "◼ Stop" : "▶ Play all")
                </button>
                <div class="layer-count">
                    @ActiveLayerCount of 4 layers ready
                </div>
            </div>

            <!-- Per-layer status -->
            <div class="player-layers">
                @foreach (var layer in Meditation.Layers.OrderBy(l => l.Type))
                {
                    var trackCount = layer.Tracks.Count();
                    var progress = GetLayerProgress(layer.Id);
                    <div class="player-layer @(layer.Muted ? "muted" : "")">
                        <span class="player-layer-icon">@LayerIcon(layer.Type)</span>
                        <div class="player-layer-info">
                            <div class="player-layer-name">@layer.Type</div>
                            <div class="player-layer-track">
                                @if (trackCount == 0)
                                {
                                    <span class="no-track">No tracks</span>
                                }
                                else if (progress is not null && !progress.Finished)
                                {
                                    <span>Track @(progress.TrackIndex + 1)/@progress.TrackCount · @FormatTime(progress.CurrentTime) / @FormatTime(progress.Duration)</span>
                                }
                                else if (progress is not null && progress.Finished)
                                {
                                    <span>Finished</span>
                                }
                                else
                                {
                                    <span>@trackCount track@(trackCount == 1 ? "" : "s") in sequence</span>
                                }
                            </div>
                            @if (trackCount > 0)
                            {
                                <div class="player-layer-progress">
                                    <div class="player-layer-progress-fill" style="@LayerProgressStyle(progress)"></div>
                                </div>
                            }
                        </div>
                        <div class="player-layer-meta">
                            Vol @((int)(layer.Volume * 100))%
                            @if (layer.Muted) { <text> · muted</text> }
                        </div>
                    </div>
                }
            </div>

            <p class="player-hint">
                Tip: Stop the player before making changes to layers or tracks.
            </p>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public MeditationDetailDto Meditation { get; set; } = null!;
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = null!;

    private bool _playing;
    private string? _sessionId;
    private System.Timers.Timer? _progressTimer;
    private Dictionary<Guid, LayerProgress> _progressByLayer = new();

    private int ActiveLayerCount =>
        Meditation.Layers.Count(l => l.Tracks.Any() && !l.Muted);

    private LayerProgress? GetLayerProgress(Guid layerId) =>
        _progressByLayer.TryGetValue(layerId, out var p) ? p : null;

    private static string LayerProgressStyle(LayerProgress? p)
    {
        var pct = (p is not null && p.Duration > 0)
            ? Math.Clamp(p.CurrentTime / p.Duration * 100.0, 0, 100)
            : 0;
        return string.Create(System.Globalization.CultureInfo.InvariantCulture, $"width: {pct:0.##}%");
    }

    private static string FormatTime(double seconds)
    {
        if (!double.IsFinite(seconds) || seconds < 0) seconds = 0;
        var total = (int)Math.Floor(seconds);
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    private async Task TogglePlay()
    {
        if (_playing) { await StopAll(); return; }
        await PlayAll();
    }

    private async Task PlayAll()
    {
        // Buduj payload: per warstwa lista tracków (url, volume, loopCount).
        var layers = Meditation.Layers
            .Where(l => l.Tracks.Any())
            .Select(l => new
            {
                id = l.Id,
                volume = l.Volume,
                muted = l.Muted,
                tracks = l.Tracks.OrderBy(t => t.Order).Select(t => new
                {
                    url = t.Asset.Url,
                    volume = t.Volume,
                    loopCount = t.LoopCount
                }).ToArray()
            }).ToArray();

        _sessionId = await JS.InvokeAsync<string>("medytaoPlayer.startSession", (object)layers);
        _playing = true;
        StartProgressTimer();
    }

    private async Task StopAll()
    {
        StopProgressTimer();
        if (_sessionId is not null)
        {
            await JS.InvokeVoidAsync("medytaoPlayer.stopSession", _sessionId);
            _sessionId = null;
        }
        _playing = false;
        _progressByLayer.Clear();
    }

    private async Task HandleClose()
    {
        if (_playing) await StopAll();
        await OnClose.InvokeAsync();
    }

    private void StartProgressTimer()
    {
        StopProgressTimer();
        _progressTimer = new System.Timers.Timer(250) { AutoReset = true };
        _progressTimer.Elapsed += OnProgressTick;
        _progressTimer.Start();
    }

    private void StopProgressTimer()
    {
        if (_progressTimer is null) return;
        _progressTimer.Elapsed -= OnProgressTick;
        _progressTimer.Stop();
        _progressTimer.Dispose();
        _progressTimer = null;
    }

    private async void OnProgressTick(object? sender, System.Timers.ElapsedEventArgs e)
    {
        var sid = _sessionId;
        if (sid is null) return;
        try
        {
            var items = await JS.InvokeAsync<LayerProgress[]>("medytaoPlayer.getProgress", sid);
            if (items is null) return;
            var map = new Dictionary<Guid, LayerProgress>(items.Length);
            foreach (var p in items)
            {
                if (p.LayerId != Guid.Empty) map[p.LayerId] = p;
            }
            _progressByLayer = map;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Komponent może być już zdisposowany lub sesja zakończona.
        }
    }

    public async ValueTask DisposeAsync()
    {
        StopProgressTimer();
        if (_sessionId is not null)
        {
            try { await JS.InvokeVoidAsync("medytaoPlayer.stopSession", _sessionId); } catch { }
            _sessionId = null;
        }
    }

    private static string LayerIcon(string type) => type switch
    {
        "Music"  => "♪",
        "Text"   => "≡",
        "Nature" => "〜",
        "Fx"     => "✦",
        _        => "○"
    };

    private sealed class LayerProgress
    {
        public int LayerIndex { get; set; }
        public Guid LayerId { get; set; }
        public int TrackIndex { get; set; }
        public int TrackCount { get; set; }
        public double CurrentTime { get; set; }
        public double Duration { get; set; }
        public bool Finished { get; set; }
    }
}

<style>
    .player-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.55);
        display: flex; align-items: center; justify-content: center;
        z-index: 300;
    }
    .player-modal {
        background: var(--color-background-primary);
        border-radius: 12px; width: 560px; max-width: 95vw;
        display: flex; flex-direction: column;
        overflow: hidden;
    }
    .player-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 18px 24px;
        border-bottom: 1px solid var(--color-border-tertiary);
    }
    .player-header h2 { font-size: 16px; font-weight: 500; margin: 0; }
    .close-btn { background: none; border: none; font-size: 22px; cursor: pointer; color: var(--color-text-secondary); line-height: 1; padding: 0; }

    .transport {
        padding: 20px 24px;
        display: flex; align-items: center; justify-content: space-between;
        border-bottom: 1px solid var(--color-border-tertiary);
    }
    .play-btn {
        padding: 10px 24px; border-radius: 6px;
        background: var(--color-text-primary); color: var(--color-background-primary);
        border: none; font-size: 14px; font-weight: 500; cursor: pointer;
    }
    .layer-count { font-size: 13px; color: var(--color-text-secondary); }

    .player-layers { padding: 8px 0; }
    .player-layer {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 24px;
        transition: opacity 0.2s;
    }
    .player-layer.muted { opacity: 0.4; }

    .player-layer-icon { font-size: 18px; color: var(--color-text-secondary); width: 24px; text-align: center; }
    .player-layer-info { flex: 1; min-width: 0; }
    .player-layer-name { font-size: 13px; font-weight: 500; }
    .player-layer-track { font-size: 11px; color: var(--color-text-tertiary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .player-layer-track .no-track { font-style: italic; }
    .player-layer-meta { font-size: 11px; color: var(--color-text-tertiary); white-space: nowrap; }

    .player-layer-progress {
        margin-top: 6px;
        height: 3px;
        background: var(--color-border-tertiary);
        border-radius: 2px;
        overflow: hidden;
    }
    .player-layer-progress-fill {
        height: 100%;
        background: var(--color-text-info);
        transition: width 0.2s linear;
    }

    .player-hint {
        padding: 12px 24px; margin: 0;
        border-top: 1px solid var(--color-border-tertiary);
        font-size: 12px; color: var(--color-text-tertiary);
    }
</style>
