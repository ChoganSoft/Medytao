@* Bottom-docked player bar — miksuje wszystkie 4 warstwy jednocześnie.
   W każdej warstwie tracki grają sekwencyjnie (wg Order).
   Track z LoopCount=0 zapętla się w nieskończoność i blokuje kolejne w warstwie.
   Logika sekwencji siedzi w window.medytaoPlayer (audioPreview.js).

   Wersja "persistent": pasek zostaje otwarty po zatrzymaniu playbacku — zamyka
   go dopiero kliknięcie X. Dzięki temu user może w dowolnej chwili wrócić do
   playu, a canvas z warstwami nadal jest dostępny i można regulować głośności
   w czasie rzeczywistym (patrz PlaybackSessionService). *@

@implements IAsyncDisposable
@inject PlaybackSessionService PlaybackSession

@if (Open)
{
    <div class="player-bar">
        <div class="player-bar-transport">
            <button class="player-play-btn @(_playing ? "playing" : "")" @onclick="TogglePlay" title="@(_playing ? "Stop" : "Play all")">
                @(_playing ? "◼" : "▶")
            </button>
            <div class="player-bar-title-wrap">
                <div class="player-bar-title">@Meditation.Title</div>
                <div class="player-bar-subtitle">
                    @if (_playing)
                    {
                        <span>Playing · @ActiveLayerCount of 4 layers</span>
                    }
                    else
                    {
                        <span>Ready · @ActiveLayerCount of 4 layers</span>
                    }
                </div>
            </div>
        </div>

        <div class="player-bar-layers">
            @foreach (var layer in Meditation.Layers.OrderBy(l => l.Type))
            {
                var trackCount = layer.Tracks.Count();
                var progress = GetLayerProgress(layer.Id);
                <div class="player-bar-layer @(layer.Muted ? "muted" : "") @(trackCount == 0 ? "empty" : "")">
                    <span class="player-bar-layer-icon">@LayerIcon(layer.Type)</span>
                    <div class="player-bar-layer-info">
                        <div class="player-bar-layer-head">
                            <span class="player-bar-layer-name">@layer.Type</span>
                            <span class="player-bar-layer-status">
                                @if (trackCount == 0)
                                {
                                    <text>—</text>
                                }
                                else if (layer.Muted)
                                {
                                    <text>muted</text>
                                }
                                else if (progress is not null && !progress.Finished)
                                {
                                    <text>@(progress.TrackIndex + 1)/@progress.TrackCount · @FormatTime(progress.CurrentTime)</text>
                                }
                                else if (progress is not null && progress.Finished)
                                {
                                    <text>done</text>
                                }
                                else
                                {
                                    <text>@trackCount track@(trackCount == 1 ? "" : "s")</text>
                                }
                            </span>
                        </div>
                        @if (trackCount > 0)
                        {
                            <div class="player-bar-layer-progress">
                                <div class="player-bar-layer-progress-fill" style="@LayerProgressStyle(progress)"></div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <button class="player-bar-close" @onclick="HandleClose" title="Close player">×</button>
    </div>
}

@code {
    [Parameter, EditorRequired] public MeditationDetailDto Meditation { get; set; } = null!;
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    [Inject] private IJSRuntime JS { get; set; } = null!;

    private bool _playing;
    private string? _sessionId;
    private System.Timers.Timer? _progressTimer;
    private Dictionary<Guid, LayerProgress> _progressByLayer = new();

    private int ActiveLayerCount =>
        Meditation.Layers.Count(l => l.Tracks.Any() && !l.Muted);

    private LayerProgress? GetLayerProgress(Guid layerId) =>
        _progressByLayer.TryGetValue(layerId, out var p) ? p : null;

    private static string LayerProgressStyle(LayerProgress? p)
    {
        var pct = (p is not null && p.Duration > 0)
            ? Math.Clamp(p.CurrentTime / p.Duration * 100.0, 0, 100)
            : 0;
        return string.Create(System.Globalization.CultureInfo.InvariantCulture, $"width: {pct:0.##}%");
    }

    private static string FormatTime(double seconds)
    {
        if (!double.IsFinite(seconds) || seconds < 0) seconds = 0;
        var total = (int)Math.Floor(seconds);
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    private async Task TogglePlay()
    {
        if (_playing) { await StopAll(); return; }
        await PlayAll();
    }

    private async Task PlayAll()
    {
        // Buduj payload: per warstwa lista tracków (url, volume, loopCount).
        var layers = Meditation.Layers
            .Where(l => l.Tracks.Any())
            .Select(l => new
            {
                id = l.Id,
                volume = l.Volume,
                muted = l.Muted,
                tracks = l.Tracks.OrderBy(t => t.Order).Select(t => new
                {
                    trackId = t.Id,
                    url = t.Asset.Url,
                    volume = t.Volume,
                    loopCount = t.LoopCount
                }).ToArray()
            }).ToArray();

        _sessionId = await JS.InvokeAsync<string>("medytaoPlayer.startSession", (object)layers);
        PlaybackSession.SetActiveSession(_sessionId);
        _playing = true;
        StartProgressTimer();
    }

    // Wersja "persistent": Stop tylko zatrzymuje playback — pasek zostaje.
    private async Task StopAll()
    {
        StopProgressTimer();
        if (_sessionId is not null)
        {
            await JS.InvokeVoidAsync("medytaoPlayer.stopSession", _sessionId);
            _sessionId = null;
        }
        PlaybackSession.ClearActiveSession();
        _playing = false;
        _progressByLayer.Clear();
    }

    // X — jedyny sposób na zamknięcie paska. Jeżeli coś gra, zatrzymujemy po drodze.
    private async Task HandleClose()
    {
        if (_playing) await StopAll();
        await OnClose.InvokeAsync();
    }

    private void StartProgressTimer()
    {
        StopProgressTimer();
        _progressTimer = new System.Timers.Timer(250) { AutoReset = true };
        _progressTimer.Elapsed += OnProgressTick;
        _progressTimer.Start();
    }

    private void StopProgressTimer()
    {
        if (_progressTimer is null) return;
        _progressTimer.Elapsed -= OnProgressTick;
        _progressTimer.Stop();
        _progressTimer.Dispose();
        _progressTimer = null;
    }

    private async void OnProgressTick(object? sender, System.Timers.ElapsedEventArgs e)
    {
        var sid = _sessionId;
        if (sid is null) return;
        try
        {
            var items = await JS.InvokeAsync<LayerProgress[]>("medytaoPlayer.getProgress", sid);
            if (items is null) return;
            var map = new Dictionary<Guid, LayerProgress>(items.Length);
            foreach (var p in items)
            {
                if (p.LayerId != Guid.Empty) map[p.LayerId] = p;
            }
            _progressByLayer = map;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Komponent może być już zdisposowany lub sesja zakończona.
        }
    }

    public async ValueTask DisposeAsync()
    {
        StopProgressTimer();
        if (_sessionId is not null)
        {
            try { await JS.InvokeVoidAsync("medytaoPlayer.stopSession", _sessionId); } catch { }
            _sessionId = null;
        }
        PlaybackSession.ClearActiveSession();
    }

    private static string LayerIcon(string type) => type switch
    {
        "Music"  => "♪",
        "Text"   => "≡",
        "Nature" => "〜",
        "Fx"     => "✦",
        _        => "○"
    };

    private sealed class LayerProgress
    {
        public int LayerIndex { get; set; }
        public Guid LayerId { get; set; }
        public int TrackIndex { get; set; }
        public int TrackCount { get; set; }
        public double CurrentTime { get; set; }
        public double Duration { get; set; }
        public bool Finished { get; set; }
    }
}

<style>
    .player-bar {
        position: fixed;
        left: 0; right: 0; bottom: 0;
        background: var(--color-background-primary);
        border-top: 1px solid var(--color-border-tertiary);
        box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.08);
        padding: 12px 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        z-index: 200;
    }

    .player-bar-transport {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 0 0 auto;
        min-width: 180px;
        max-width: 240px;
    }

    .player-play-btn {
        width: 40px; height: 40px;
        flex: 0 0 auto;
        border-radius: 50%;
        border: none;
        background: var(--color-text-primary);
        color: var(--color-background-primary);
        font-size: 14px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.1s;
    }
    .player-play-btn:hover { transform: scale(1.05); }
    .player-play-btn.playing {
        background: var(--color-text-info);
    }

    .player-bar-title-wrap {
        display: flex;
        flex-direction: column;
        min-width: 0;
        flex: 1;
    }
    .player-bar-title {
        font-size: 13px;
        font-weight: 500;
        color: var(--color-text-primary);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .player-bar-subtitle {
        font-size: 11px;
        color: var(--color-text-tertiary);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    .player-bar-layers {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
        min-width: 0;
    }

    .player-bar-layer {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
        transition: opacity 0.2s;
    }
    .player-bar-layer.muted { opacity: 0.4; }
    .player-bar-layer.empty { opacity: 0.35; }

    .player-bar-layer-icon {
        font-size: 16px;
        color: var(--color-text-secondary);
        width: 20px;
        text-align: center;
        flex: 0 0 auto;
    }

    .player-bar-layer-info {
        flex: 1;
        min-width: 0;
    }

    .player-bar-layer-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 8px;
        line-height: 1.2;
    }
    .player-bar-layer-name {
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text-primary);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .player-bar-layer-status {
        font-size: 10px;
        color: var(--color-text-tertiary);
        white-space: nowrap;
        flex: 0 0 auto;
    }

    .player-bar-layer-progress {
        margin-top: 4px;
        height: 3px;
        background: var(--color-border-tertiary);
        border-radius: 2px;
        overflow: hidden;
    }
    .player-bar-layer-progress-fill {
        height: 100%;
        background: var(--color-text-info);
        transition: width 0.2s linear;
    }

    .player-bar-close {
        flex: 0 0 auto;
        background: none;
        border: none;
        font-size: 22px;
        line-height: 1;
        color: var(--color-text-secondary);
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 4px;
        transition: background 0.1s, color 0.1s;
    }
    .player-bar-close:hover {
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
    }

    @@media (max-width: 900px) {
        .player-bar-layers {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }
        .player-bar-transport {
            min-width: 140px;
        }
    }
</style>
