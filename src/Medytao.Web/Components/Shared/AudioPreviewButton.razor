@* Przycisk Play/Pause + pasek postępu dla pojedynczego pliku audio.
   Używa natywnego <audio> + helperów w window.medytaoAudio.
   Pasek jest zawsze widoczny obok przycisku — wypełnia się podczas odtwarzania. *@

@implements IAsyncDisposable

<span class="audio-preview-wrap" @onclick:stopPropagation="true">
    <button class="audio-preview-btn @(_playing ? "playing" : "")"
            @onclick="Toggle"
            title="@(_playing ? "Stop" : "Preview")">
        @if (_playing)
        {
            <span>◼</span>
        }
        else
        {
            <span>▶</span>
        }
    </button>

    @{
        const double ringRadius = 13d;
        var ringCirc = 2 * Math.PI * ringRadius;
        var ringOffset = ringCirc * (1 - ProgressFraction);
        var hasProgress = _duration > 0;
    }
    <span class="audio-preview-ring-wrap"
          title="@(hasProgress ? FormatTime(_currentTime) + " / " + FormatTime(_duration) : "")">
        <svg class="audio-preview-ring @(_playing ? "active" : "")"
             width="32" height="32" viewBox="0 0 32 32"
             aria-hidden="true">
            <circle class="ring-bg" cx="16" cy="16" r="@(ringRadius.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
            @if (hasProgress)
            {
                <circle class="ring-fill" cx="16" cy="16" r="@(ringRadius.ToString(System.Globalization.CultureInfo.InvariantCulture))"
                        stroke-dasharray="@(ringCirc.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))"
                        stroke-dashoffset="@(ringOffset.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))" />
            }
        </svg>
    </span>
</span>

<audio @ref="_audioRef" src="@Url" preload="metadata" @onended="HandleEnded" @onloadedmetadata="HandleLoadedMetadata"></audio>

@code {
    [Parameter, EditorRequired] public string Url { get; set; } = "";
    /// <summary>
    /// Głośność odtwarzania preview (0–1). Odświeża się na żywo, gdy user
    /// rusza suwakiem — komponent łapie zmianę w OnParametersSetAsync
    /// i puka do JS, żeby aktualny <audio> natychmiast zmienił wolumen.
    /// </summary>
    [Parameter] public float Volume { get; set; } = 1.0f;

    [Inject] private IJSRuntime JS { get; set; } = null!;

    private ElementReference _audioRef;
    private bool _playing;
    private double _currentTime;
    private double _duration;
    private float _lastAppliedVolume = float.NaN;
    private System.Timers.Timer? _progressTimer;

    // 0.0 .. 1.0 — ułamek odtworzony. Używane przez SVG ring do policzenia
    // stroke-dashoffset.
    private double ProgressFraction =>
        _duration > 0 ? Math.Clamp(_currentTime / _duration, 0, 1) : 0;

    private static string FormatTime(double seconds)
    {
        if (!double.IsFinite(seconds) || seconds < 0) seconds = 0;
        var total = (int)Math.Floor(seconds);
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    private async Task Toggle()
    {
        if (_playing)
        {
            // stop (nie pause) — zjeżdżamy do zera, żeby ring wrócił do pustego
            // i następny play zaczął od początku. Taki jest kontrakt tego
            // przycisku (ikona ◼), mimo że pod spodem <audio> dalej żyje.
            await JS.InvokeVoidAsync("medytaoAudio.stop", _audioRef);
            StopProgressTimer();
            _playing = false;
            _currentTime = 0;
        }
        else
        {
            // Zatrzymaj każde inne odtwarzanie na stronie.
            await JS.InvokeVoidAsync("medytaoAudio.pauseAll");
            await JS.InvokeVoidAsync("medytaoAudio.play", _audioRef, Volume);
            _lastAppliedVolume = Volume;
            _playing = true;
            StartProgressTimer();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Jeżeli rodzic zmienił Volume w czasie gdy preview gra,
        // puknij JS-owi, żeby zastosował nową głośność na żywo.
        if (_playing && Math.Abs(_lastAppliedVolume - Volume) > 0.0001f)
        {
            try
            {
                await JS.InvokeVoidAsync("medytaoAudio.setVolume", _audioRef, Volume);
                _lastAppliedVolume = Volume;
            }
            catch { }
        }
    }

    private async Task HandleLoadedMetadata()
    {
        // Pozyskaj długość, żeby pasek miał sens jeszcze przed playem.
        try
        {
            var p = await JS.InvokeAsync<ProgressDto?>("medytaoAudio.getProgress", _audioRef);
            if (p is not null)
            {
                _duration = p.duration;
                StateHasChanged();
            }
        }
        catch { }
    }

    private void HandleEnded()
    {
        _playing = false;
        _currentTime = 0;
        StopProgressTimer();
    }

    private void StartProgressTimer()
    {
        StopProgressTimer();
        _progressTimer = new System.Timers.Timer(200) { AutoReset = true };
        _progressTimer.Elapsed += OnProgressTick;
        _progressTimer.Start();
    }

    private void StopProgressTimer()
    {
        if (_progressTimer is null) return;
        _progressTimer.Elapsed -= OnProgressTick;
        _progressTimer.Stop();
        _progressTimer.Dispose();
        _progressTimer = null;
    }

    private async void OnProgressTick(object? sender, System.Timers.ElapsedEventArgs e)
    {
        try
        {
            var p = await JS.InvokeAsync<ProgressDto?>("medytaoAudio.getProgress", _audioRef);
            if (p is null) return;
            _currentTime = p.currentTime;
            _duration = p.duration;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Komponent może być już zdisposowany.
        }
    }

    public async ValueTask DisposeAsync()
    {
        StopProgressTimer();
        if (_playing)
        {
            try { await JS.InvokeVoidAsync("medytaoAudio.pause", _audioRef); } catch { }
        }
    }

    private sealed record ProgressDto(double currentTime, double duration);
}

<style>
    .audio-preview-wrap {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .audio-preview-btn {
        background: none;
        border: 1px solid var(--color-border-secondary);
        border-radius: 50%;
        width: 28px; height: 28px;
        flex: 0 0 auto;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer;
        font-size: 11px;
        color: var(--color-text-secondary);
        padding: 0;
        transition: all 0.1s;
    }
    .audio-preview-btn:hover {
        color: var(--color-text-primary);
        border-color: var(--color-border-primary);
    }
    .audio-preview-btn.playing {
        background: var(--color-text-info);
        color: var(--color-background-primary);
        border-color: var(--color-text-info);
    }
    /* Okrągły wskaźnik postępu dla preview tracka. Spójny z ringiem
       warstwy w LayerPanel — ta sama geometria (32x32, r=13). */
    .audio-preview-ring-wrap {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px; height: 32px;
    }
    .audio-preview-ring {
        transform: rotate(-90deg);
    }
    .audio-preview-ring .ring-bg {
        fill: none;
        stroke: var(--color-border-tertiary);
        stroke-width: 2.5;
        opacity: 0.5;
    }
    .audio-preview-ring.active .ring-bg {
        opacity: 1;
    }
    .audio-preview-ring .ring-fill {
        fill: none;
        stroke: var(--color-text-info);
        stroke-width: 2.5;
        stroke-linecap: round;
        transition: stroke-dashoffset 0.18s linear;
    }
</style>
