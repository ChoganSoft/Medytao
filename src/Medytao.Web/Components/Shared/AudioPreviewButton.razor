@* Przycisk Play/Pause dla pojedynczego pliku audio.
   Używa natywnego <audio> + helperów w window.medytaoAudio.
   Podczas odtwarzania pokazuje cienki pasek postępu pod przyciskiem. *@

@implements IAsyncDisposable

<span class="audio-preview-wrap">
    <button class="audio-preview-btn @(_playing ? "playing" : "")"
            @onclick:stopPropagation="true"
            @onclick="Toggle"
            title="@(_playing ? "Pause" : "Preview")">
        @if (_playing)
        {
            <span>◼</span>
        }
        else
        {
            <span>▶</span>
        }
    </button>

    @if (_playing)
    {
        <span class="audio-preview-progress">
            <span class="audio-preview-progress-fill" style="@ProgressStyle"></span>
        </span>
    }
</span>

<audio @ref="_audioRef" src="@Url" preload="none" @onended="HandleEnded"></audio>

@code {
    [Parameter, EditorRequired] public string Url { get; set; } = "";

    [Inject] private IJSRuntime JS { get; set; } = null!;

    private ElementReference _audioRef;
    private bool _playing;
    private double _currentTime;
    private double _duration;
    private System.Timers.Timer? _progressTimer;

    private double ProgressPercent =>
        _duration > 0 ? Math.Clamp(_currentTime / _duration * 100.0, 0, 100) : 0;

    private string ProgressStyle =>
        string.Create(System.Globalization.CultureInfo.InvariantCulture, $"width: {ProgressPercent:0.##}%");

    private async Task Toggle()
    {
        if (_playing)
        {
            await JS.InvokeVoidAsync("medytaoAudio.pause", _audioRef);
            StopProgressTimer();
            _playing = false;
        }
        else
        {
            // Zatrzymaj każde inne odtwarzanie na stronie
            await JS.InvokeVoidAsync("medytaoAudio.pauseAll");
            await JS.InvokeVoidAsync("medytaoAudio.play", _audioRef);
            _playing = true;
            StartProgressTimer();
        }
    }

    private void HandleEnded()
    {
        _playing = false;
        _currentTime = 0;
        StopProgressTimer();
    }

    private void StartProgressTimer()
    {
        StopProgressTimer();
        _progressTimer = new System.Timers.Timer(200) { AutoReset = true };
        _progressTimer.Elapsed += OnProgressTick;
        _progressTimer.Start();
    }

    private void StopProgressTimer()
    {
        if (_progressTimer is null) return;
        _progressTimer.Elapsed -= OnProgressTick;
        _progressTimer.Stop();
        _progressTimer.Dispose();
        _progressTimer = null;
    }

    private async void OnProgressTick(object? sender, System.Timers.ElapsedEventArgs e)
    {
        try
        {
            var p = await JS.InvokeAsync<ProgressDto?>("medytaoAudio.getProgress", _audioRef);
            if (p is null) return;
            _currentTime = p.currentTime;
            _duration = p.duration;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Komponent może być już zdisposowany.
        }
    }

    public async ValueTask DisposeAsync()
    {
        StopProgressTimer();
        if (_playing)
        {
            try { await JS.InvokeVoidAsync("medytaoAudio.pause", _audioRef); } catch { }
        }
    }

    private sealed record ProgressDto(double currentTime, double duration);
}

<style>
    .audio-preview-wrap {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
    }
    .audio-preview-btn {
        background: none;
        border: 1px solid var(--color-border-secondary);
        border-radius: 50%;
        width: 28px; height: 28px;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer;
        font-size: 11px;
        color: var(--color-text-secondary);
        padding: 0;
        transition: all 0.1s;
    }
    .audio-preview-btn:hover {
        color: var(--color-text-primary);
        border-color: var(--color-border-primary);
    }
    .audio-preview-btn.playing {
        background: var(--color-text-info);
        color: var(--color-background-primary);
        border-color: var(--color-text-info);
    }
    .audio-preview-progress {
        position: absolute;
        left: 0; right: 0;
        bottom: -6px;
        height: 2px;
        background: var(--color-border-tertiary);
        border-radius: 1px;
        overflow: hidden;
        pointer-events: none;
    }
    .audio-preview-progress-fill {
        display: block;
        height: 100%;
        background: var(--color-text-info);
        transition: width 0.18s linear;
    }
</style>
