@* Przycisk Play/Pause dla pojedynczego pliku audio.
   Używa natywnego <audio> + helperów w window.medytaoAudio. *@

<button class="audio-preview-btn @(_playing ? "playing" : "")"
        @onclick:stopPropagation="true"
        @onclick="Toggle"
        title="@(_playing ? "Pause" : "Preview")">
    @if (_playing)
    {
        <span>◼</span>
    }
    else
    {
        <span>▶</span>
    }
</button>

<audio @ref="_audioRef" src="@Url" preload="none" @onended="HandleEnded"></audio>

@code {
    [Parameter, EditorRequired] public string Url { get; set; } = "";

    [Inject] private IJSRuntime JS { get; set; } = null!;

    private ElementReference _audioRef;
    private bool _playing;

    private async Task Toggle()
    {
        if (_playing)
        {
            await JS.InvokeVoidAsync("medytaoAudio.pause", _audioRef);
            _playing = false;
        }
        else
        {
            // Zatrzymaj każde inne odtwarzanie na stronie
            await JS.InvokeVoidAsync("medytaoAudio.pauseAll");
            await JS.InvokeVoidAsync("medytaoAudio.play", _audioRef);
            _playing = true;
        }
    }

    private void HandleEnded() => _playing = false;
}

<style>
    .audio-preview-btn {
        background: none;
        border: 1px solid var(--color-border-secondary);
        border-radius: 50%;
        width: 28px; height: 28px;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer;
        font-size: 11px;
        color: var(--color-text-secondary);
        padding: 0;
        transition: all 0.1s;
    }
    .audio-preview-btn:hover {
        color: var(--color-text-primary);
        border-color: var(--color-border-primary);
    }
    .audio-preview-btn.playing {
        background: var(--color-text-info);
        color: var(--color-background-primary);
        border-color: var(--color-text-info);
    }
</style>
