@inherits LayoutComponentBase
@implements IDisposable
@inject AuthService Auth
@inject NavigationManager Nav
@inject ThemeService Theme
@inject Blazored.LocalStorage.ISyncLocalStorageService Storage

<div class="app-shell @(_sidebarCollapsed ? "sidebar-collapsed" : "")">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-avatar">
                <img src="img/meditation-avatar.png" alt="" />
            </div>
            <div class="brand-text">
                <span class="brand-bold">MEDYTAO</span>
                <span class="brand-light">SYSTEM</span>
            </div>
        </div>
        <nav class="sidebar-nav">
            @* Ikony FA dobrane semantycznie: program = warstwy medytacji
               (layer-group), kategoria = tag, asset library = audio (music),
               sign out = nowy FA "right-from-bracket" (stary "sign-out-alt"
               nadal działa jako alias, ale preferujemy v6-native nazwy). *@
            <NavLink href="/" Match="NavLinkMatch.All" class="nav-item" title="My programs">
                <i class="nav-icon fa-solid fa-layer-group" aria-hidden="true"></i>
                <span class="nav-label">My programs</span>
            </NavLink>
            <NavLink href="/categories" class="nav-item" title="Categories">
                <i class="nav-icon fa-solid fa-tags" aria-hidden="true"></i>
                <span class="nav-label">Categories</span>
            </NavLink>
            <NavLink href="/assets" class="nav-item" title="Asset library">
                <i class="nav-icon fa-solid fa-music" aria-hidden="true"></i>
                <span class="nav-label">Asset library</span>
            </NavLink>
        </nav>
        <div class="sidebar-footer">
            <button class="nav-item logout-btn" @onclick="Logout" title="Sign out">
                <i class="nav-icon fa-solid fa-right-from-bracket" aria-hidden="true"></i>
                <span class="nav-label">Sign out</span>
            </button>
        </div>
    </aside>

    <div class="main-column">
        <header class="top-bar">
            <button class="sidebar-toggle" @onclick="ToggleSidebar" title="Toggle sidebar" aria-label="Toggle sidebar">
                <i class="fa-solid fa-bars" aria-hidden="true"></i>
            </button>
            <span class="top-bar-breadcrumb">@CurrentSectionName()</span>
            <div class="top-bar-spacer"></div>
            <button class="theme-toggle" @onclick="ToggleTheme"
                    title="@(Theme.IsDark ? "Switch to light theme" : "Switch to dark theme")">
                @(Theme.IsDark ? "☀" : "☾")
            </button>
        </header>
        <main class="main-content">
            @Body
        </main>
    </div>
</div>

@code {
    // Klucz localStorage dla stanu sidebara. Ten sam styl (kropka w nazwie)
    // co theme-storage, dla spójności. Wartość: bool (true = zwinięty).
    private const string SidebarStorageKey = "medytao.sidebarCollapsed";

    // Stan zwinięcia sidebara — odczytywany z localStorage w OnInitialized,
    // zapisywany po każdym toggle. Dzięki synchronicznemu storage nie ma
    // miganięcia między pierwszym renderem (rozwinięty) a drugim (zwinięty).
    private bool _sidebarCollapsed;

    protected override void OnInitialized()
    {
        // Theme: synchronizujemy ikonę toggle'a ze stanem z localStorage
        // (inline script w index.html ustawił już klasę na <html> przed renderem).
        Theme.OnChanged += HandleThemeChanged;
        Theme.Initialize();

        // Sidebar: wczytanie zapamiętanego stanu. Sync storage → dostępne
        // przed pierwszym renderem, więc nie ma efektu "najpierw rozwinięty,
        // potem skok do zwinięcia".
        try
        {
            _sidebarCollapsed = Storage.GetItem<bool>(SidebarStorageKey);
        }
        catch
        {
            // Private mode / brak localStorage → zostaje domyślny (rozwinięty).
            _sidebarCollapsed = false;
        }

        // Re-render topbara przy każdej nawigacji — breadcrumb pokazuje aktualną
        // sekcję wywiedzioną z URL-a, więc po przejściu /programs → /categories
        // etykieta musi się odświeżyć.
        Nav.LocationChanged += HandleLocationChanged;
    }

    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private Task ToggleTheme() => Theme.ToggleAsync();

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
        try { Storage.SetItem(SidebarStorageKey, _sidebarCollapsed); } catch { }
    }

    // Breadcrumb w topbarze — pojedyncza etykieta nazwy sekcji (nie pełna ścieżka
    // typu "Home › Programs › Details"). Na stronie głównej pokazujemy "Home"
    // dla spójności z designem, na pozostałych — nazwę sekcji. Strony
    // szczegółowe (programs/{id}, meditations/{id}) dostają ogólny label;
    // konkretny tytuł i tak pojawia się wewnątrz page-headera.
    private string CurrentSectionName()
    {
        var relative = Nav.ToBaseRelativePath(Nav.Uri);
        var path = relative.Split('?')[0].Trim('/');
        if (string.IsNullOrEmpty(path)) return "Home";
        return path switch
        {
            "categories" => "Categories",
            "assets" => "Asset library",
            "login" => "Login",
            "register" => "Register",
            var p when p.StartsWith("programs/") => "Program",
            var p when p.StartsWith("meditations/") => "Meditation editor",
            _ => "Home"
        };
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        Theme.OnChanged -= HandleThemeChanged;
        Nav.LocationChanged -= HandleLocationChanged;
    }
}

<style>
    /* Sidebar zachowuje stały granatowy kolor (#012e48) niezależnie od motywu —
       zawartość bazuje na przezroczystej bieli, żeby kontrast był niezmienny
       w trybie jasnym i ciemnym. Motyw dotyczy wyłącznie prawej kolumny. */

    .app-shell { display: flex; height: 100vh; overflow: hidden; }

    .sidebar {
        width: 240px; min-width: 240px;
        background: #012e48;
        /* Cień po prawej — lekka głębia, żeby sidebar "unosił się" nad content'em
           (efekt 3D). Wcześniejszy border-right na półprzezroczystej bieli
           i tak był niewidoczny na granatowym tle; shadow daje realne
           oddzielenie warstwy w obu motywach. z-index zapewnia, że cień
           faktycznie kładzie się na main-content, a nie odwrotnie. */
        box-shadow: 4px 0 14px rgba(0, 0, 0, 0.18);
        position: relative; z-index: 1;
        display: flex; flex-direction: column;
        padding: 0;
        color: rgba(255,255,255,0.85);
        transition: width 0.22s ease, min-width 0.22s ease;
        overflow: hidden;
    }
    /* Zwinięty sidebar → wąski pasek (64px) z samymi ikonami. Width animuje się
       płynnie; tekst znika natychmiast (display:none), co zapobiega "zawijaniu
       się" napisów w trakcie animacji. */
    .app-shell.sidebar-collapsed .sidebar {
        width: 64px; min-width: 64px;
    }

    .sidebar-brand {
        display: flex; align-items: center; gap: 12px;
        padding: 14px 20px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        color: #ffffff;
        min-height: 72px;
        flex-shrink: 0;
    }
    /* W trybie zwiniętym sam awatar, wycentrowany — padding zmniejszony
       z 20px do 10px, żeby 44px awatara zmieściło się w 64px sidebarze. */
    .sidebar-collapsed .sidebar-brand {
        padding: 14px 10px;
        justify-content: center;
    }
    .sidebar-collapsed .brand-text { display: none; }

    .brand-avatar {
        width: 44px; height: 44px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
        display: inline-flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        overflow: hidden;
    }
    .brand-avatar img { width: 100%; height: 100%; display: block; }

    /* Wordmark: MEDYTAO pogrubione, SYSTEM wyraźnie mniejszy i w spacjowanej
       kapitalizacji — lekki, wtórny deskryptor pod nazwą, zgodnie z mockupem.
       Line-height 1 + ręczny gap 2px, bo domyślne 1.2 dla 20px robiłoby
       za duży odstęp między wierszami. */
    .brand-text {
        display: flex; flex-direction: column;
        gap: 2px;
        line-height: 1;
        white-space: nowrap;
    }
    .brand-bold {
        font-size: 20px; font-weight: 700;
        letter-spacing: 0.02em;
    }
    .brand-light {
        font-size: 10px; font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.28em;
        opacity: 0.7;
    }

    .sidebar-nav { display: flex; flex-direction: column; gap: 2px; padding: 12px 8px; flex: 1; }

    .nav-item {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 14px; border-radius: 6px;
        font-size: 14px; color: rgba(255,255,255,0.7);
        text-decoration: none; cursor: pointer;
        background: none; border: none; width: 100%; text-align: left;
        transition: background 0.15s, color 0.15s;
        white-space: nowrap;
        overflow: hidden;
    }

    .nav-item:hover, .nav-item.active {
        background: rgba(255,255,255,0.08);
        color: #ffffff;
    }

    .nav-icon {
        font-size: 15px; opacity: 0.8;
        flex-shrink: 0;
        width: 20px; text-align: center;
    }
    .nav-label { min-width: 0; overflow: hidden; text-overflow: ellipsis; }

    /* Collapsed: nav-item to sam wycentrowany icon. Tekst znika (display:none)
       żeby nie zawijał się w trakcie animacji zwijania; tooltip (`title`) na
       nav-linku zapewnia nadal dostęp do etykiety po hoverze. */
    .sidebar-collapsed .nav-item {
        justify-content: center;
        padding: 10px 0;
        gap: 0;
    }
    .sidebar-collapsed .nav-label { display: none; }

    .sidebar-footer {
        padding: 8px 8px 16px;
        border-top: 1px solid rgba(255,255,255,0.08);
        margin-top: auto;
    }

    .logout-btn { color: rgba(255,255,255,0.5); }
    .logout-btn:hover { color: rgba(255,255,255,0.9); background: rgba(255,255,255,0.06); }

    /* Prawa kolumna: top-bar (pasek nawigacyjny) + główny scrollowalny content.
       Topbar ma stałą wysokość, content zajmuje resztę i sam scrolluje. */
    .main-column {
        flex: 1;
        display: flex; flex-direction: column;
        min-width: 0;
        overflow: hidden;
    }

    .top-bar {
        display: flex; align-items: center; gap: 16px;
        height: 56px;
        padding: 0 24px;
        background: var(--color-background-primary);
        border-bottom: 1px solid var(--color-border-tertiary);
        flex-shrink: 0;
    }
    .sidebar-toggle {
        width: 36px; height: 36px;
        border: none; background: transparent;
        border-radius: 6px;
        color: var(--color-text-secondary);
        font-size: 16px; line-height: 1;
        cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0;
        transition: background 0.15s, color 0.15s;
    }
    .sidebar-toggle:hover {
        background: var(--color-background-secondary);
        color: var(--color-text-primary);
    }
    .top-bar-breadcrumb {
        font-size: 15px;
        color: var(--color-text-primary);
        font-weight: 400;
    }
    .top-bar-spacer { flex: 1; }

    /* Theme toggle przeniesiony z sidebara do topbara — naturalne miejsce na
       globalne akcje UI, poza tym paleta "ciemny sidebar" kolidowała wizualnie
       z kółkiem toggle'a. Tutaj cieniujemy się zmiennymi motywu. */
    .theme-toggle {
        width: 32px; height: 32px;
        border: 1px solid var(--color-border-secondary);
        border-radius: 50%;
        background: transparent;
        color: var(--color-text-secondary);
        font-size: 13px; line-height: 1;
        cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0;
        transition: color 0.15s, border-color 0.15s, background 0.15s;
    }
    .theme-toggle:hover {
        background: var(--color-background-secondary);
        border-color: var(--color-text-primary);
        color: var(--color-text-primary);
    }

    .main-content { flex: 1; overflow-y: auto; background: var(--color-background-tertiary); }
</style>
